// ============================================
// INTERVIEW MESSAGES (Admin ↔ Applicant Chat)
// ============================================

model InterviewMessage {
  id            String         @id @default(cuid())
  applicationId String
  senderId      String? // platform user ID if admin, null for applicant
  senderName    String // display name
  content       String
  isFromAdmin   Boolean        @default(false)
  createdAt     DateTime       @default(now())
  application   JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([createdAt])
}

// ============================================
// FEATURE 2: VIDEO LESSON CHECKPOINTS
// ============================================

model VideoCheckpoint {
  id            String                    @id @default(cuid())
  lessonId      String
  timestamp     Int // in seconds
  question      String
  questionType  String                    @default("MCQ") // MCQ, TRUE_FALSE
  options       String? // JSON array for MCQ options
  correctAnswer String? // index for MCQ, "true"/"false" for TF
  explanation   String? // shown after answer
  order         Int                       @default(0)
  isRequired    Boolean                   @default(true) // must answer to continue
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  lesson        VideoLesson               @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  progress      VideoCheckpointProgress[]

  @@index([lessonId])
  @@index([timestamp])
}

model VideoCheckpointProgress {
  id           String          @id @default(cuid())
  studentId    String
  checkpointId String
  answer       String?
  isCorrect    Boolean         @default(false)
  answeredAt   DateTime        @default(now())
  timeSpent    Int? // seconds spent on this checkpoint
  student      Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  checkpoint   VideoCheckpoint @relation(fields: [checkpointId], references: [id], onDelete: Cascade)

  @@unique([studentId, checkpointId])
  @@index([studentId])
  @@index([checkpointId])
}

model StudentVideoProgress {
  id            String   @id @default(cuid())
  studentId     String
  lessonId      String
  progress      Int      @default(0) // 0-100 percentage
  completed     Boolean  @default(false)
  lastWatchedAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  student Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lesson  VideoLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([studentId, lessonId])
  @@index([studentId])
  @@index([lessonId])
}

// ============================================
// FEATURE 3: TEACHER EVALUATION & TASKS
// ============================================

model TeacherTask {
  id                 String                     @id @default(cuid())
  schoolId           String
  teacherId          String
  title              String
  description        String?
  taskType           String // "reading", "lesson_plan", "report", "meeting", "class_management", "other"
  dueDate            DateTime?
  priority           String                     @default("medium") // low, medium, high, urgent
  status             String                     @default("pending") // pending, in_progress, completed, overdue
  createdBy          String // userId of admin/head teacher
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  school             School                     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher            Teacher                    @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  attachments        TeacherTaskAttachment[]
  completions        TeacherTaskCompletion[]
  readingAssignments TeacherReadingAssignment[]

  @@index([schoolId])
  @@index([teacherId])
  @@index([status])
  @@index([dueDate])
}

model TeacherTaskAttachment {
  id        String      @id @default(cuid())
  taskId    String
  name      String
  url       String
  type      String      @default("document")
  createdAt DateTime    @default(now())
  task      TeacherTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model TeacherTaskCompletion {
  id            String      @id @default(cuid())
  taskId        String
  teacherId     String
  notes         String?
  attachmentUrl String?
  completedAt   DateTime    @default(now())
  verifiedBy    String? // userId who verified
  verifiedAt    DateTime?
  status        String      @default("pending") // pending, approved, rejected
  feedback      String? // feedback from verifier
  task          TeacherTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  teacher       Teacher     @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([taskId, teacherId])
  @@index([taskId])
  @@index([teacherId])
  @@index([status])
}

model TeacherPerformance {
  id                   String   @id @default(cuid())
  schoolId             String
  teacherId            String
  termId               String
  taskCompletionScore  Int      @default(0) // From tasks completed
  punctualityScore     Int      @default(0) // Staff attendance
  classScore           Int      @default(0) // Class management quality
  studentFeedbackScore Int      @default(0) // Average from student evaluations
  weeklyEvalScore      Int      @default(0) // From weekly evaluations
  totalScore           Int      @default(0)
  rank                 Int?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  school               School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher              Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  term                 Term     @relation(fields: [termId], references: [id])

  @@unique([teacherId, termId])
  @@index([schoolId])
  @@index([termId])
  @@index([totalScore])
}

// Teacher task assignment for reading materials
model TeacherReadingAssignment {
  id        String       @id @default(cuid())
  taskId    String
  bookId    String?
  content   String? // Text content to read
  pageRange String? // e.g. "1-50" or "Chapter 1-3"
  notes     String?
  task      TeacherTask  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  book      LibraryBook? @relation(fields: [bookId], references: [id])

  @@index([taskId])
  @@index([bookId])
}

// ============================================
// FEATURE 4: STUDENT LEADERBOARDS
// ============================================

model StudentPerformanceSnapshot {
  id              String   @id @default(cuid())
  schoolId        String
  studentId       String
  date            DateTime @db.Date
  gpa             Float    @default(0)
  attendanceScore Int      @default(0) // Based on daily attendance (0-100)
  behaviorScore   Int      @default(0) // From daily behavior log (0-100)
  homeworkScore   Int      @default(0) // Homework submission rate (0-100)
  evaluationScore Int      @default(0) // From weekly evaluations (0-100)
  totalScore      Int      @default(0) // Weighted total
  dailyRank       Int?
  weeklyRank      Int?
  termRank        Int?
  yearlyRank      Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  school          School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([schoolId])
  @@index([date])
  @@index([totalScore])
  @@index([dailyRank])
  @@index([weeklyRank])
  @@index([termRank])
  @@index([yearlyRank])
}

model Leaderboard {
  id         String   @id @default(cuid())
  schoolId   String
  type       String // "daily", "weekly", "termly", "yearly"
  classId    String?
  level      String? // e.g. "JSS1", "SS1", "Year 10"
  department String? // For secondary schools: Science, Arts, Commercial
  period     String // e.g. "2025-01-15", "2025-week-3", "2025-1st-term"
  data       String // JSON: [{rank, studentId, studentName, score, badges}]
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class      Class?   @relation(fields: [classId], references: [id])

  @@unique([schoolId, type, classId, level, department, period])
  @@index([schoolId])
  @@index([type])
  @@index([period])
}

model PerformanceBadge {
  id          String   @id @default(cuid())
  schoolId    String
  studentId   String
  badgeType   String // "daily_best", "weekly_best", "termly_best", "yearly_best", "improver", "consistent"
  title       String
  description String?
  icon        String? // emoji or icon name
  score       Int? // score achieved
  rank        Int? // rank achieved
  period      String // the period this badge is for
  awardedAt   DateTime @default(now())
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([studentId])
  @@index([badgeType])
  @@index([awardedAt])
}

// Motivational messages for students
model EncouragementMessage {
  id        String    @id @default(cuid())
  schoolId  String
  studentId String

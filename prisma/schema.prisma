  roomNumber String
  floor      Int      @default(1)
  capacity   Int      @default(4)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  hostel      Hostel             @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  beds        HostelBed[]
  allocations HostelAllocation[]

  @@unique([hostelId, roomNumber])
  @@index([hostelId])
}

model HostelBed {
  id         String   @id @default(cuid())
  roomId     String
  bedNumber  String
  isOccupied Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  room       HostelRoom        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  allocation HostelAllocation?

  @@unique([roomId, bedNumber])
  @@index([roomId])
}

model HostelAllocation {
  id          String    @id @default(cuid())
  schoolId    String
  studentId   String
  hostelId    String
  roomId      String
  bedId       String    @unique
  startDate   DateTime
  endDate     DateTime?
  status      String    @default("active") // active | transferred | vacated
  allocatedBy String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  school  School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student Student    @relation(fields: [studentId], references: [id])
  hostel  Hostel     @relation(fields: [hostelId], references: [id])
  room    HostelRoom @relation(fields: [roomId], references: [id])
  bed     HostelBed  @relation(fields: [bedId], references: [id])

  @@unique([studentId, status])
  @@index([schoolId])
  @@index([hostelId])
  @@index([roomId])
  @@index([status])
}

// ============================================================================
// INVENTORY / ASSET MANAGEMENT
// ============================================================================

model InventoryCategory {
  id          String   @id @default(cuid())
  schoolId    String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  items  InventoryItem[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model InventoryItem {
  id            String    @id @default(cuid())
  schoolId      String
  categoryId    String?
  name          String
  description   String?
  quantity      Int       @default(1)
  minQuantity   Int       @default(0)
  unit          String?
  condition     String    @default("new") // new | good | fair | poor | damaged
  purchaseDate  DateTime?
  purchasePrice Float?
  supplier      String?
  location      String?
  serialNumber  String?
  barcode       String?
  notes         String?
  isConsumable  Boolean   @default(false)
  status        String    @default("available") // available | in_use | under_maintenance | retired
  assignedTo    String?
  imageUrl      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  school   School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  category InventoryCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@index([categoryId])
  @@index([status])
  @@index([condition])
}

// ============================================================================
// ALUMNI MANAGEMENT
// ============================================================================

model Alumni {
  id                String   @id @default(cuid())
  schoolId          String
  studentId         String   @unique
  graduationYear    Int
  graduationTerm    String?
  finalClass        String?
  finalGpa          Float?
  currentOccupation String?
  employer          String?
  email             String?
  phone             String?
  address           String?
  city              String?
  country           String?
  linkedinUrl       String?
  facebookUrl       String?
  newsletterOptIn   Boolean  @default(true)
  isActive          Boolean  @default(true)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  school  School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student Student           @relation(fields: [studentId], references: [id])
  rsvps   AlumniEventRSVP[]

  @@index([schoolId])
  @@index([graduationYear])
  @@index([currentOccupation])
}

model AlumniEvent {
  id           String    @id @default(cuid())
  schoolId     String
  title        String
  description  String?
  eventDate    DateTime
  location     String?
  isVirtual    Boolean   @default(false)
  meetingLink  String?
  organizer    String?
  rsvpDeadline DateTime?
  maxAttendees Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  school School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  rsvps  AlumniEventRSVP[]

  @@index([schoolId])
  @@index([eventDate])
}

model AlumniEventRSVP {
  id        String   @id @default(cuid())
  eventId   String
  alumniId  String
  status    String   @default("pending") // pending | attending | not_attending
  guests    Int      @default(0)
  message   String?
  createdAt DateTime @default(now())

  event  AlumniEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  alumni Alumni      @relation(fields: [alumniId], references: [id], onDelete: Cascade)

  @@unique([eventId, alumniId])
  @@index([eventId])
  @@index([alumniId])
}

// ============================================================================
// CLUBS & SOCIETIES
// ============================================================================

model Club {
  id            String    @id @default(cuid())
  schoolId      String
  name          String
  description   String?
  mission       String?
  patronName    String?
  patronId      String?
  meetingDay    String?
  meetingTime   String?
  meetingVenue  String?
  membershipFee Float?    @default(0)
  isActive      Boolean   @default(true)
  logo          String?
  socialLink    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  school  School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  patron  Teacher?         @relation(fields: [patronId], references: [id])
  members ClubMembership[]
  events  ClubEvent[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model ClubMembership {
  id         String   @id @default(cuid())
  clubId     String
  studentId  String
  role       String   @default("member") // president | vice_president | secretary | treasurer | member
  joinedDate DateTime @default(now())
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  club    Club    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([clubId, studentId])
  @@index([clubId])
  @@index([studentId])
  @@index([role])
}

model ClubEvent {
  id          String   @id @default(cuid())
  clubId      String
  schoolId    String
  title       String
  description String?
  eventDate   DateTime
  location    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@index([schoolId])
  @@index([eventDate])
}

// ============================================================================
// ENROLLMENT / TRANSFER HISTORY
// ============================================================================

model EnrollmentHistory {
  id             String   @id @default(cuid())
  schoolId       String
  studentId      String
  action         String // enrollment | transfer_in | transfer_out | class_change | graduation | withdrawal | reinstatement
  fromClassId    String?
  toClassId      String?
  fromSchoolId   String?
  toSchoolId     String?
  fromSchoolName String?
  toSchoolName   String?
  academicYearId String?
  termId         String?
  reason         String?
  notes          String?
  performedBy    String?
  createdAt      DateTime @default(now())

  school    School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student   Student @relation(fields: [studentId], references: [id])
  fromClass Class?  @relation("FromClass", fields: [fromClassId], references: [id])
  toClass   Class?  @relation("ToClass", fields: [toClassId], references: [id])

  @@index([schoolId])
  @@index([studentId])
  @@index([action])
  @@index([createdAt])
}

// ============================================================================
// GUEST USER SYSTEM — anonymous users for live classes & monetization
// ============================================================================

model GuestUser {
  id                String   @id @default(cuid())
  email             String   @unique
  name              String?
  emailVerified     Boolean  @default(false)
  verificationToken String?
  credits           Int      @default(0)
  hasUsedFreeTrial  Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  liveClasses LiveClass[]
  payments    GuestPayment[]
}

model GuestPayment {
  id          String   @id @default(cuid())
  guestUserId String
  amount      Int // in kobo (₦500 = 50000)
  credits     Int // 1 per ₦500
  reference   String   @unique
  status      String   @default("pending") // pending | success | failed
  createdAt   DateTime @default(now())

  guestUser GuestUser @relation(fields: [guestUserId], references: [id])

  @@index([guestUserId])
}

// ─── Salary / Payroll Models ──────────────────────────────────────────────────

model StaffSalary {
  id                 String   @id @default(cuid())
  schoolId           String
  userId             String   @unique
  role               String // "TEACHER" | "ACCOUNTANT" | "LIBRARIAN" | "DIRECTOR" | "SCHOOL_ADMIN"
  baseSalary         Float
  housingAllowance   Float    @default(0)
  transportAllowance Float    @default(0)
  medicalAllowance   Float    @default(0)
  bonus              Float    @default(0)
  otherAllowances    String? // JSON — e.g. {"lessonNote":5000,"examSupervision":3000}
  bankName           String?
  accountNumber      String?
  accountName        String?
  taxId              String?
  pensionNumber      String?
  effectiveDate      DateTime
  isActive           Boolean  @default(true)
  createdById        String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  school    School @relation(fields: [schoolId], references: [id])
  user      User   @relation(fields: [userId], references: [id])
  createdBy User   @relation("SalaryCreatedBy", fields: [createdById], references: [id])

  @@unique([schoolId, userId])
  @@index([schoolId])
  @@index([userId])
}

model Payroll {
  id              String        @id @default(cuid())
  schoolId        String
  title           String
  month           Int
  year            Int
  periodStart     DateTime
  periodEnd       DateTime
  status          PayrollStatus @default(DRAFT)
  totalGrossPay   Float         @default(0)
  totalDeductions Float         @default(0)
  totalNetPay     Float         @default(0)
  staffCount      Int           @default(0)
  notes           String?
  processedById   String
  approvedById    String?
  approvedAt      DateTime?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  school      School    @relation(fields: [schoolId], references: [id])
  processedBy User      @relation("PayrollProcessedBy", fields: [processedById], references: [id])
  approvedBy  User?     @relation("PayrollApprovedBy", fields: [approvedById], references: [id])
  payslips    Payslip[]

  @@unique([schoolId, year, month])
  @@index([schoolId])
  @@index([status])
}

model Payslip {
  id                 String        @id @default(cuid())
  payrollId          String
  schoolId           String
  userId             String
  role               String
  baseSalary         Float
  housingAllowance   Float         @default(0)
  transportAllowance Float         @default(0)
  medicalAllowance   Float         @default(0)
  bonus              Float         @default(0)
  otherAllowances    String? // JSON
  grossPay           Float
  deductions         String? // JSON array — e.g. [{"label":"PAYE Tax","amount":15000}]
  totalDeductions    Float         @default(0)
  netPay             Float
  paymentStatus      PayslipStatus @default(PENDING)
  paidAt             DateTime?
  paymentMethod      String?
  paymentReference   String?
  notes              String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  payroll Payroll @relation(fields: [payrollId], references: [id])
  school  School  @relation(fields: [schoolId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([payrollId, userId])
  @@index([payrollId])
  @@index([schoolId])
  @@index([userId])
}

model SalaryAdvance {
  id               String    @id @default(cuid())
  schoolId         String
  userId           String
  amount           Float
  requestDate      DateTime  @default(now())
  reason           String?
  repaymentMonths  Int       @default(1)
  monthlyDeduction Float
  remainingBalance Float
  approvedById     String?
  approvedAt       DateTime?
  status           String    @default("PENDING") // PENDING | APPROVED | PAID | COMPLETED | REJECTED
  rejectionReason  String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  school     School @relation(fields: [schoolId], references: [id])
  user       User   @relation(fields: [userId], references: [id])
  approvedBy User?  @relation("AdvanceApprovedBy", fields: [approvedById], references: [id])

  @@index([schoolId])
  @@index([userId])
  @@index([status])
}

model DocumentTemplate {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String // "admission" | "disciplinary" | "correspondence" | "meeting" | "academic" | "general"
  content     String // Rich HTML with {{placeholders}}
  icon        String? // emoji icon
  isPreset    Boolean  @default(true)
  schoolId    String? // null for presets, set for school-customized copies
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([isPreset])
  @@index([schoolId])
}

// ── School Public Website (subdomain-based landing pages) ──
model SchoolPublicPage {
  id             String    @id @default(cuid())
  schoolId       String    @unique
  // Hero section
  heroTitle      String?
  heroSubtitle   String?
  heroImageUrl   String?
  heroVideoUrl   String?
  // About section
  aboutTitle     String?
  aboutContent   String?   // Rich text (JSON/HTML)
  aboutImages    String?   // JSON array
  // Admissions section
  admissionsTitle   String?
  admissionsContent String?   // Rich text
  // Contact section
  contactEmail    String?
  contactPhone    String?
  contactAddress  String?
  socialLinks     String?   // JSON { twitter, facebook, instagram, linkedin, youtube }
  // SEO
  metaTitle      String?
  metaDescription String?
  // Status
  isPublished    Boolean   @default(false)
  publishedAt    DateTime?
  // Custom CSS overrides for the school page
  customCss      String?
  // Reusable content blocks (JSON array of { id, type, content, order })
  extraSections  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  school School @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([isPublished])
}

  textSecondaryColor String  @default("#64748b")
  headerBgColor      String  @default("#059669")
  bgColor            String  @default("#ffffff")
  gradientFrom       String?
  gradientTo         String?

  // Background
  backgroundType  String  @default("solid") // "solid" | "gradient" | "image" | "glass"
  backgroundImage String?

  // Typography

  showAddress       Boolean @default(true)
  showContacts      Boolean @default(true)
  showStudentPhoto  Boolean @default(true)
  showStudentInfo   Boolean @default(true)
  showSubjectsTable Boolean @default(true)
  showDomains       Boolean @default(true)
  showChart         Boolean @default(true)
  showAttendance    Boolean @default(true)
  showRemarks       Boolean @default(true)
  showSignatures    Boolean @default(true)
  showFooter        Boolean @default(true)

  createdBy      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  school School? @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([targetType])
  @@index([isBuiltIn])
}

model AssessmentRubric {
  id         String    @id @default(cuid())
  schoolId   String?
  name       String
  targetType String // student | teacher
  criteria   String? // JSON [{ name, weight, levels: [{ score, description }] }]
  createdBy  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  school School? @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([targetType])
}

model AssessmentReport {
  id              String   @id @default(cuid())
  schoolId        String
  type            String // individual | class | school | teacher
  targetStudentId String?
  targetClassId   String?
  targetTeacherId String?
  assessmentId    String?
  termId          String?
  reportData      String? // JSON — complete report data
  pdfUrl          String?
  generatedAt     DateTime @default(now())
  createdAt       DateTime @default(now())

  school School? @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([type])
  @@index([targetStudentId])
  @@index([targetClassId])
  @@index([targetTeacherId])
  @@index([generatedAt])
}

model AIAssessmentConfig {
  id                String   @id @default(cuid())
  schoolId          String   @unique
  aiEnabled         Boolean  @default(true)
  provider          String   @default("auto") // auto | openrouter | fallback
  aiQuestionGen     Boolean  @default(true)
  aiGrading         Boolean  @default(true)
  aiRecommendations Boolean  @default(true)
  aiProfileAnalysis Boolean  @default(true)
  aiReportGen       Boolean  @default(true)
  aiModel           String   @default("auto") // auto (legacy field, kept for migration compat)
  apiKeyEncrypted   String? // encrypted API key, nullable (falls back to platform key)
  openrouterKey     String? // OpenRouter API key
  primaryModel      String   @default("google/gemma-4-31b-it:free") // primary OpenRouter model
  fallbackModel1    String   @default("nvidia/nemotron-3-super-120b-a12b:free") // first fallback
  fallbackModel2    String   @default("qwen/qwen3-8b") // second fallback
  fallbackModel3    String   @default("microsoft/phi-4-mini-instruct") // third fallback
  maxRetries        Int      @default(2)
  requestTimeoutMs  Int      @default(15000)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
}


  updatedAt  DateTime @updatedAt
  author     HubUser  @relation(fields: [hubUserId], references: [id], onDelete: Cascade)

  @@index([hubUserId])
  @@index([category])
  @@index([isFeatured])
}

model HubAchievement {
  id           String   @id @default(cuid())
  hubUserId    String
  type         String
  title        String
  description  String?
  icon         String?
  pointsEarned Int      @default(0)
  createdAt    DateTime @default(now())
  author       HubUser  @relation(fields: [hubUserId], references: [id], onDelete: Cascade)

  @@unique([hubUserId, type])
  @@index([hubUserId])
  @@index([type])
}

model Conversation {
  id             String    @id @default(cuid())
  schoolId       String
  type           String    @default("direct")
  title          String?
  participantIds String
  lastMessage    String?
  lastMessageAt  DateTime?
  createdBy      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  school         School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  messages       Message[]

  @@index([schoolId])
  @@index([createdAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  schoolId       String

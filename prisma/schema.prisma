generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ─────────────────────────────────────────────────────────────────
enum UserRole {
  SUPER_ADMIN
  SCHOOL_ADMIN
  TEACHER
  STUDENT
  PARENT
  ACCOUNTANT
  LIBRARIAN
  DIRECTOR
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  VERIFIED
  PENDING_VERIFICATION
}

enum ExamStatus {
  DRAFT
  PUBLISHED
  LOCKED
  ACTIVE
}

enum HomeworkStatus {
  ACTIVE
  CLOSED
  ARCHIVED
}

enum LessonPlanStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum PayrollStatus {
  DRAFT
  APPROVED
  PAID
  CANCELLED
}

enum PayslipStatus {
  PENDING
  PAID
  FAILED
}

model School {
  id                                String                             @id @default(cuid())
  name                              String
  slug                              String                             @unique
  logo                              String?
  address                           String?
  motto                             String?
  phone                             String?
  email                             String?
  website                           String?
  primaryColor                      String                             @default("#059669")
  secondaryColor                    String                             @default("#10B981")
  region                            String?
  plan                              String                             @default("free")
  schoolType                        String? // "primary" | "secondary" | "primary_secondary" | "higher_institution"
  tokenVersion                      Int                                @default(0)
  isActive                          Boolean                            @default(true)
  maxStudents                       Int                                @default(500)
  maxTeachers                       Int                                @default(50)
  liveClassMaxParticipants          Int                                @default(50)
  liveClassMaxDuration              Int                                @default(60)
  liveClassMaxConcurrent            Int                                @default(5)
  liveClassMaxMeetingsPerMonth      Int                                @default(100)
  foundedDate                       DateTime?
  createdAt                         DateTime                           @default(now())
  updatedAt                         DateTime                           @updatedAt
  deletedAt                         DateTime?
  planId                            String?
  academicYears                     AcademicYear[]
  accountants                       Accountant[]
  achievements                      Achievement[]
  announcements                     Announcement[]
  attendances                       Attendance[]
  attendanceScanLogs                AttendanceScanLog[]
  auditLogs                         AuditLog[]
  behaviorLogs                      BehaviorLog[]
  borrowRecords                     BorrowRecord[]
  classes                           Class[]
  conversations                     Conversation[]
  directors                         Director[]
  domainGrades                      DomainGrade[]
  entranceExams                     EntranceExam[]
  exams                             Exam[]
  exportLogs                        ExportLog[]
  feeStructures                     FeeStructure[]
  feedbacks                         Feedback[]
  healthRecords                     HealthRecord[]
  homeworks                         Homework[]
  homeworkQuestions                 HomeworkQuestion[]
  homeworkAnswers                   HomeworkQuestionAnswer[]
  homeworkSubmissions               HomeworkSubmission[]
  idCardDesigns                     IDCardDesign[]
  iDCards                           IDCard[]
  jobPostings                       JobPosting[]
  librarians                        Librarian[]
  books                             LibraryBook[]
  messages                          Message[]
  notificationList                  Notification[]
  parents                           Parent[]
  payments                          Payment[]
  platformPayments                  PlatformPayment[]
  registrationCodes                 RegistrationCode[]
  reportCards                       ReportCard[]
  reportCardDesigns                 ReportCardDesign[]
  gradeScales                       GradeScale[]
  promotionRules                    PromotionRule[]
  subscriptionPlan                  SubscriptionPlan?                  @relation("SchoolPlan", fields: [planId], references: [id])
  events                            SchoolEvent[]
  schoolNotices                     SchoolNotice[]
  settings                          SchoolSettings?
  scoreTypes                        ScoreType[]
  students                          Student[]
  studentDiaries                    StudentDiary[]
  subjects                          Subject[]
  supportTickets                    SupportTicket[]
  teachers                          Teacher[]
  teacherComments                   TeacherComment[]
  terms                             Term[]
  transportRoutes                   TransportRoute[]
  users                             User[]
  videoLessons                      VideoLesson[]
  liveClasses                       LiveClass[]
  weeklyEvaluations                 WeeklyEvaluation[]
  teacherTasks                      TeacherTask[]
  teacherPerformance                TeacherPerformance[]
  staffAttendances                  StaffAttendance[]
  performanceSnapshots              StudentPerformanceSnapshot[]
  leaderboards                      Leaderboard[]
  performanceBadges                 PerformanceBadge[]
  encouragements                    EncouragementMessage[]
  expenses                          Expense[]
  schemeOfWorks                     SchemeOfWork[]
  lessonPlans                       LessonPlan[]
  // Assessment Hub relations
  studentAssessments                StudentAssessment[]
  studentAssessmentAttempts         StudentAssessmentAttempt[]
  studentSkillProfiles              StudentSkillProfile[]
  studentLearningStyleProfiles      StudentLearningStyleProfile[]
  studentRecommendations            StudentRecommendation[]
  studentGrowthRecords              StudentGrowthRecord[]
  teacherAssessments                TeacherAssessment[]
  teacherAssessmentAttempts         TeacherAssessmentAttempt[]
  teacher360FeedbackEntries         Teacher360FeedbackEntry[]
  teacherCompetencyProfiles         TeacherCompetencyProfile[]
  teacherDevelopmentRecommendations TeacherDevelopmentRecommendation[]
  teacherObservationRecords         TeacherObservationRecord[]
  assessmentTemplates               AssessmentTemplate[]
  assessmentRubrics                 AssessmentRubric[]
  assessmentReports                 AssessmentReport[]
  aiAssessmentConfigs               AIAssessmentConfig[]
  // Hostel management
  hostels                           Hostel[]
  hostelAllocations                 HostelAllocation[]
  // Inventory
  inventoryCategories               InventoryCategory[]
  inventoryItems                    InventoryItem[]
  // Alumni
  alumni                            Alumni[]
  alumniEvents                      AlumniEvent[]
  // Clubs
  clubs                             Club[]
  clubEvents                        ClubEvent[]
  // Enrollment history
  enrollmentHistory                 EnrollmentHistory[]
  // Timetables
  timetables                        Timetable[]
  // Salary / Payroll
  staffSalaries                     StaffSalary[]
  payrolls                          Payroll[]
  payslips                          Payslip[]
  salaryAdvances                    SalaryAdvance[]
  trustedSchool                     TrustedSchool?
  bankName                          String?
  bankAccountName                   String?
  bankAccountNumber                 String?
  publicPage                        SchoolPublicPage?

  @@index([slug])
  @@index([region])
}

model TrustedSchool {
  id           String   @id @default(cuid())
  schoolId     String   @unique
  trustedOrder Int      @default(0)
  promotedById String
  promotedAt   DateTime @default(now())

  school   School @relation(fields: [schoolId], references: [id])
  promoter User   @relation(fields: [promotedById], references: [id])

  @@index([trustedOrder])
}

model RegistrationCode {
  id        String    @id @default(cuid())
  code      String    @unique
  plan      String    @default("free")
  region    String?
  maxUses   Int       @default(1)
  usedCount Int       @default(0)
  expiresAt DateTime?
  isUsed    Boolean   @default(false)
  createdBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  schoolId  String?
  school    School?   @relation(fields: [schoolId], references: [id])

  @@index([code])
  @@index([schoolId])
}

model User {
  id                      String                 @id @default(cuid())
  email                   String                 @unique
  password                String?
  name                    String
  username                String?
  avatar                  String?
  phone                   String?
  role                    String
  schoolId                String?
  isActive                Boolean                @default(true)
  lastLogin               DateTime?
  loginCount              Int                    @default(0)
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  deletedAt               DateTime?
  emailVerified           DateTime?
  resetToken              String?
  resetTokenExpiry        DateTime?
  // Separate tokens for email verification and password reset
  emailVerificationToken  String?
  emailVerificationExpiry DateTime?
  passwordResetToken      String?
  passwordResetExpiry     DateTime?
  // Profile fields
  passportNumber          String?
  dateOfBirth             DateTime?
  gender                  String?
  address                 String?
  nationality             String?
  emergencyContact        String?
  emergencyPhone          String?
  bloodGroup              String?
  maritalStatus           String?
  nextOfKin               String?
  nextOfKinPhone          String?
  accountantProfile       Accountant?
  auditLogs               AuditLog[]             @relation("AuditLogsByUser")
  directorProfile         Director?
  librarianProfile        Librarian?
  notifications           Notification[]
  parentProfile           Parent?
  pushSubscriptions       PushSubscription[]
  studentProfile          Student?
  teacherProfile          Teacher?
  school                  School?                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  sessions                UserSession[]
  messagesSent            Message[]              @relation("SentMessages")
  staffAttendances        StaffAttendance[]
  attendanceScanLogs      AttendanceScanLog[]
  liveClassesHosted       LiveClass[]            @relation("HostedClasses")
  liveClassParticipations LiveClassParticipant[]
  liveClassPollVotes      LiveClassPollVote[]
  preferences             UserPreferences?
  staffSalary             StaffSalary?
  payslips                Payslip[]
  salaryAdvances          SalaryAdvance[]
  salariesCreated         StaffSalary[]          @relation("SalaryCreatedBy")
  payrollsProcessed       Payroll[]              @relation("PayrollProcessedBy")
  payrollsApproved        Payroll[]              @relation("PayrollApprovedBy")
  advancesApproved        SalaryAdvance[]        @relation("AdvanceApprovedBy")
  trustedSchoolsPromoted  TrustedSchool[]

  @@index([schoolId])
  @@index([role])
}

model UserSession {
  id        String    @id @default(cuid())
  userId    String
  token     String?
  ipAddress String?
  userAgent String?
  loginAt   DateTime  @default(now())
  logoutAt  DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

model AcademicYear {
  id            String         @id @default(cuid())
  schoolId      String
  name          String
  startDate     DateTime
  endDate       DateTime
  isCurrent     Boolean        @default(false)
  isLocked      Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  school        School         @relation(fields: [schoolId], references: [id])
  terms         Term[]
  schemeOfWorks SchemeOfWork[]
  timetables    Timetable[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model Term {
  id                   String                @id @default(cuid())
  academicYearId       String
  schoolId             String
  name                 String
  order                Int
  startDate            DateTime
  endDate              DateTime
  isCurrent            Boolean               @default(false)
  isLocked             Boolean               @default(false)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  deletedAt            DateTime?
  attendance           Attendance[]
  exams                Exam[]
  reportCards          ReportCard[]
  teacherComments      TeacherComment[]
  teacherPerformance   TeacherPerformance[]
  academicYear         AcademicYear          @relation(fields: [academicYearId], references: [id])
  school               School                @relation(fields: [schoolId], references: [id])
  schemeOfWorks        SchemeOfWork[]
  // Assessment Hub relations
  studentAssessments   StudentAssessment[]
  teacherAssessments   TeacherAssessment[]
  studentGrowthRecords StudentGrowthRecord[]
  timetables           Timetable[]
  timetableSlots       TimetableSlot[]

  @@unique([academicYearId, order])
  @@index([schoolId])
}

model Timetable {
  id             String    @id @default(cuid())
  schoolId       String
  academicYearId String
  termId         String?
  name           String
  description    String?
  isActive       Boolean   @default(true)
  isPublished    Boolean   @default(false)
  weekStartDate  DateTime?
  weekEndDate    DateTime?
  createdBy      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  school       School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear AcademicYear    @relation(fields: [academicYearId], references: [id])
  term         Term?           @relation(fields: [termId], references: [id])
  slots        TimetableSlot[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([academicYearId])
  @@index([termId])
}

model TimetableSlot {
  id                  String   @id @default(cuid())
  timetableId         String
  termId              String
  dayOfWeek           Int // 0 = Sunday, 1 = Monday, ..., 6 = Saturday
  period              Int // Period number (1, 2, 3, etc.)
  startTime           String // "08:00"
  endTime             String // "08:40"
  classId             String
  subjectId           String
  teacherId           String?
  room                String?
  isBreak             Boolean  @default(false)
  isCancelled         Boolean  @default(false)
  cancelReason        String?
  location            String?
  schemeOfWorkEntryId String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  timetable         Timetable          @relation(fields: [timetableId], references: [id], onDelete: Cascade)
  term              Term               @relation(fields: [termId], references: [id])
  class             Class              @relation(fields: [classId], references: [id])
  subject           Subject            @relation(fields: [subjectId], references: [id])
  teacher           Teacher?           @relation(fields: [teacherId], references: [id])
  schemeOfWorkEntry SchemeOfWorkEntry? @relation(fields: [schemeOfWorkEntryId], references: [id])

  @@unique([timetableId, dayOfWeek, period, classId])
  @@index([timetableId])
  @@index([classId])
  @@index([teacherId])
  @@index([termId])
  @@index([schemeOfWorkEntryId])
  @@index([dayOfWeek])
  @@index([isCancelled])
}

// ─── Scheme of Work ───────────────────────────────────────────────────────────

model SchemeOfWork {
  id             String    @id @default(cuid())
  schoolId       String
  academicYearId String
  termId         String
  classId        String
  subjectId      String
  title          String?
  description    String?
  isPublished    Boolean   @default(false)
  createdBy      String
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  school       School              @relation(fields: [schoolId], references: [id])
  academicYear AcademicYear        @relation(fields: [academicYearId], references: [id])
  term         Term                @relation(fields: [termId], references: [id])
  class        Class               @relation(fields: [classId], references: [id])
  subject      Subject             @relation(fields: [subjectId], references: [id])
  entries      SchemeOfWorkEntry[]

  @@unique([schoolId, termId, subjectId, classId])
  @@index([schoolId])
  @@index([classId])
  @@index([subjectId])
  @@index([termId])
}

model SchemeOfWorkEntry {
  id                 String    @id @default(cuid())
  schemeOfWorkId     String
  weekNumber         Int
  topic              String
  subTopic           String?
  learningObjectives String?
  teachingActivities String?
  learningActivities String?
  resources          String?
  assessmentMethod   String?
  duration           Int?
  status             String    @default("pending") // pending | in_progress | completed
  completedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  schemeOfWork   SchemeOfWork    @relation(fields: [schemeOfWorkId], references: [id], onDelete: Cascade)
  timetableSlots TimetableSlot[]

  @@unique([schemeOfWorkId, weekNumber])
  @@index([schemeOfWorkId])
  @@index([status])
}

model LessonPlan {
  id                String   @id @default(cuid())
  schoolId          String
  subjectId         String?
  classId           String?
  teacherId         String?
  topic             String
  content           String? // NEW: markdown lesson note body for students to study
  objectives        String?
  activities        String?
  resources         String?
  quiz              String? // JSON: array of { type, questionText, options, correctAnswer, marks }
  masteryThresholds String? // NEW: JSON like {"beginner":0,"intermediate":40,"advanced":60,"mastered":80}
  status            String   @default("draft") // draft | published | archived
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  school   School              @relation(fields: [schoolId], references: [id])
  subject  Subject?            @relation(fields: [subjectId], references: [id])
  class    Class?              @relation(fields: [classId], references: [id])
  attempts LessonPlanAttempt[]

  @@index([schoolId])
  @@index([subjectId])
  @@index([classId])
  @@index([teacherId])
}

model LessonPlanAttempt {
  id            String    @id @default(cuid())
  planId        String
  schoolId      String
  studentId     String
  attemptNumber Int       @default(1) // NEW: incremented per re-attempt
  answers       String? // JSON map of questionIndex -> answer
  score         Float?
  totalMarks    Int       @default(0)
  masteryLevel  String? // NEW: "beginner" | "intermediate" | "advanced" | "mastered"
  passed        Boolean?
  startedAt     DateTime  @default(now())
  completedAt   DateTime?

  lessonPlan LessonPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  student    Student    @relation(fields: [studentId], references: [id])

  @@unique([planId, studentId, attemptNumber])
  @@index([planId])
  @@index([studentId])
}

model Class {
  id                    String              @id @default(cuid())
  schoolId              String
  name                  String
  section               String?
  grade                 String?
  capacity              Int                 @default(40)
  classTeacherId        String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  deletedAt             DateTime?
  classTeacher          Teacher?            @relation("ClassTeacher", fields: [classTeacherId], references: [id])
  school                School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subjects              ClassSubject[]
  exams                 Exam[]
  homeworks             Homework[]
  students              Student[]
  attendances           Attendance[]
  feeStructures         FeeStructureClass[]
  leaderboards          Leaderboard[]
  schemeOfWorks         SchemeOfWork[]
  lessonPlans           LessonPlan[]
  liveClasses           LiveClass[]
  timetableSlots        TimetableSlot[]
  enrollmentHistoryFrom EnrollmentHistory[] @relation("FromClass")
  enrollmentHistoryTo   EnrollmentHistory[] @relation("ToClass")

  @@unique([schoolId, name, section])
  @@index([schoolId])
}

model Subject {
  id                    String                 @id @default(cuid())
  schoolId              String
  name                  String
  code                  String?
  type                  String                 @default("core")
  description           String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  deletedAt             DateTime?
  classes               ClassSubject[]
  exams                 Exam[]
  examQuestions         ExamQuestion[]
  homeworks             Homework[]
  homeworkQuestions     HomeworkQuestion[]
  entranceExamQuestions EntranceExamQuestion[]
  lessonQuizQuestions   LessonQuizQuestion[]
  school                School                 @relation(fields: [schoolId], references: [id])
  schemeOfWorks         SchemeOfWork[]
  lessonPlans           LessonPlan[]
  timetableSlots        TimetableSlot[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model ClassSubject {
  id        String   @id @default(cuid())
  classId   String
  subjectId String
  teacherId String?
  createdAt DateTime @default(now())
  class     Class    @relation(fields: [classId], references: [id])
  subject   Subject  @relation(fields: [subjectId], references: [id])
  teacher   Teacher? @relation(fields: [teacherId], references: [id])

  @@unique([classId, subjectId])
  @@index([classId])
  @@index([subjectId])
}

model Student {
  id                      String                       @id @default(cuid())
  schoolId                String
  userId                  String                       @unique
  admissionNo             String
  classId                 String?
  dateOfBirth             DateTime?
  gender                  String?
  address                 String?
  bloodGroup              String?
  allergies               String?
  emergencyContact        String?
  photo                   String?
  house                   String?
  isPromoted              Boolean                      @default(true)
  gpa                     Float                        @default(0.0)
  cumulativeGpa           Float                        @default(0.0)
  rank                    Int?
  behaviorScore           Int                          @default(100)
  isActive                Boolean                      @default(true)
  createdAt               DateTime                     @default(now())
  updatedAt               DateTime                     @updatedAt
  deletedAt               DateTime?
  achievements            Achievement[]
  attendance              Attendance[]
  behaviorLogs            BehaviorLog[]
  borrowRecords           BorrowRecord[]
  examAttempts            ExamAttempt[]
  examScores              ExamScore[]
  homeworkSubmissions     HomeworkSubmission[]
  payments                Payment[]
  reportCards             ReportCard[]
  class                   Class?                       @relation(fields: [classId], references: [id])
  school                  School                       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user                    User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  teacherComments         TeacherComment[]
  weeklyEvaluations       WeeklyEvaluation[]
  studentParents          StudentParent[]              @relation("StudentParents")
  videoCheckpointProgress VideoCheckpointProgress[]
  videoProgress           StudentVideoProgress[]
  performanceSnapshots    StudentPerformanceSnapshot[]
  lessonPlanAttempts      LessonPlanAttempt[]
  lessonQuizAttempts      LessonQuizAttempt[]
  badges                  PerformanceBadge[]
  encouragements          EncouragementMessage[]
  // Assessment Hub relations
  assessmentAttempts      StudentAssessmentAttempt[]
  domainResults           StudentDomainResult[]
  skillProfiles           StudentSkillProfile[]
  learningStyleProfile    StudentLearningStyleProfile?
  recommendations         StudentRecommendation[]
  growthRecords           StudentGrowthRecord[]
  // Hostel
  hostelAllocations       HostelAllocation[]
  // Alumni
  alumni                  Alumni?
  // Clubs
  clubMemberships         ClubMembership[]
  // Enrollment history
  enrollmentHistory       EnrollmentHistory[]

  @@unique([schoolId, admissionNo])
  @@index([schoolId])
  @@index([classId])
}

model Teacher {
  id                         String                             @id @default(cuid())
  schoolId                   String
  userId                     String                             @unique
  employeeNo                 String
  specialization             String?
  qualification              String?
  dateOfJoining              DateTime?
  gender                     String?
  phone                      String?
  address                    String?
  photo                      String?
  salary                     Float?
  isActive                   Boolean                            @default(true)
  createdAt                  DateTime                           @default(now())
  updatedAt                  DateTime                           @updatedAt
  deletedAt                  DateTime?
  attendanceScanLogs         AttendanceScanLog[]
  classes                    Class[]                            @relation("ClassTeacher")
  classSubjects              ClassSubject[]
  exams                      Exam[]
  homeworks                  Homework[]
  school                     School                             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user                       User                               @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments                   TeacherComment[]
  weeklyEvaluations          WeeklyEvaluation[]
  tasks                      TeacherTask[]
  taskCompletions            TeacherTaskCompletion[]
  performances               TeacherPerformance[]
  // Assessment Hub relations
  assessmentAttempts         TeacherAssessmentAttempt[]
  feedbackEntries            Teacher360FeedbackEntry[]
  competencyProfiles         TeacherCompetencyProfile[]
  developmentRecommendations TeacherDevelopmentRecommendation[]
  observationRecords         TeacherObservationRecord[]
  timetableSlots             TimetableSlot[]
  clubsPatroned              Club[]

  @@unique([schoolId, employeeNo])
  @@index([schoolId])
}

model Parent {
  id             String          @id @default(cuid())
  schoolId       String
  userId         String          @unique
  occupation     String?
  phone          String?
  address        String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?
  school         School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentStudents StudentParent[] @relation("ParentStudents")

  @@index([schoolId])
}

model StudentParent {
  id        String   @id @default(cuid())
  studentId String
  parentId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  student   Student  @relation("StudentParents", fields: [studentId], references: [id], onDelete: Cascade)
  parent    Parent   @relation("ParentStudents", fields: [parentId], references: [id], onDelete: Cascade)

  @@unique([studentId, parentId])
  @@index([studentId])
  @@index([parentId])
}

model Accountant {
  id         String    @id @default(cuid())
  schoolId   String
  userId     String    @unique
  employeeNo String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  school     School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([schoolId])
}

model Librarian {
  id         String    @id @default(cuid())
  schoolId   String
  userId     String    @unique
  employeeNo String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  school     School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([schoolId])
}

model Director {
  id         String    @id @default(cuid())
  schoolId   String
  userId     String    @unique
  employeeNo String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  school     School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([schoolId])
}

model Exam {
  id               String                @id @default(cuid())
  schoolId         String
  termId           String
  subjectId        String
  classId          String
  teacherId        String?
  name             String
  type             String                @default("assessment")
  totalMarks       Int                   @default(100)
  passingMarks     Int                   @default(50)
  date             DateTime?
  /// Duration in minutes
  duration         Int?
  instructions     String?
  isLocked         Boolean               @default(false)
  isPublished      Boolean               @default(false)
  /// JSON string storing exam security settings (active approach; ExamSecuritySettings model reserved for future structured migration)
  securitySettings String?
  allowCalculator  Boolean               @default(true)
  /// "basic" or "scientific"
  calculatorMode   String                @default("basic")
  shuffleQuestions Boolean               @default(false)
  shuffleOptions   Boolean               @default(false)
  /// Show score to student after submission
  showResult       Boolean               @default(false)
  /// Penalty marks per wrong answer (0 = no negative marking)
  negativeMarking  Float                 @default(0)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  deletedAt        DateTime?
  scoreTypeId      String?
  class            Class                 @relation(fields: [classId], references: [id])
  school           School                @relation(fields: [schoolId], references: [id])
  scoreType        ScoreType?            @relation(fields: [scoreTypeId], references: [id])
  subject          Subject               @relation(fields: [subjectId], references: [id])
  teacher          Teacher?              @relation(fields: [teacherId], references: [id])
  term             Term                  @relation(fields: [termId], references: [id])
  security         ExamSecuritySettings?
  attempts         ExamAttempt[]
  questions        ExamQuestion[]
  scores           ExamScore[]

  @@index([schoolId])
  @@index([termId])
  @@index([classId])
  @@index([schoolId, termId, classId])
  @@index([schoolId, deletedAt])
}

model ExamSecuritySettings {
  id                     String   @id @default(cuid())
  examId                 String   @unique
  blockCopyPaste         Boolean  @default(false)
  monitorTabSwitch       Boolean  @default(false)
  maxTabSwitches         Int?     @default(3)
  monitorWebcam          Boolean  @default(false)
  randomizeQuestions     Boolean  @default(false)
  randomizeOptions       Boolean  @default(false)
  fullscreenMode         Boolean  @default(false)
  blockRightClick        Boolean  @default(false)
  blockKeyboardShortcuts Boolean  @default(false)
  showResultAfterSubmit  Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([examId])
}

model ExamQuestion {
  id            String   @id @default(cuid())
  examId        String
  /// MCQ, MULTI_SELECT, TRUE_FALSE, FILL_BLANK, SHORT_ANSWER, ESSAY, MATCHING
  type          String   @default("MCQ")
  questionText  String
  /// For MCQ/MULTI_SELECT/TRUE_FALSE: JSON array of option strings. For MATCHING: JSON { pairs: [{left, right}] }
  options       String?
  /// Correct answer: MCQ=string index/letter, MULTI_SELECT=array, TRUE_FALSE="true"/"false", FILL_BLANK=array of acceptable answers, SHORT_ANSWER=string/array, ESSAY=markdown rubric, MATCHING=JSON
  correctAnswer String?
  marks         Int      @default(1)
  /// Explanation shown after grading
  explanation   String?
  /// Image/video/diagram URL for the question
  mediaUrl      String?
  /// Display order
  order         Int      @default(0)
  /// Word limit for ESSAY type questions
  wordLimit     Int?
  /// Subject this question belongs to (for cross-subject exams / analytics grouping)
  subjectId     String?
  /// Topic tag for analytics grouping
  topic         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  subject       Subject? @relation(fields: [subjectId], references: [id])

  @@index([examId])
  @@index([order])
  @@index([subjectId])
}

model ExamAttempt {
  id                 String    @id @default(cuid())
  examId             String
  studentId          String
  /// JSON map of questionId -> answer (string for MCQ/TRUE_FALSE/FILL_BLANK/SHORT_ANSWER, array for MULTI_SELECT, string for ESSAY, JSON for MATCHING)
  answers            String?
  /// Auto-graded score (for objective questions)
  autoScore          Float?
  /// Teacher-graded score (for subjective questions)
  manualScore        Float?
  /// Combined score
  finalScore         Float?
  /// in_progress, submitted, graded, timed_out, disqualified
  status             String    @default("in_progress")
  startedAt          DateTime  @default(now())
  submittedAt        DateTime?
  gradedAt           DateTime?
  /// JSON array of security violations: [{ type: "tab_switch", timestamp, count }]
  securityViolations String?
  tabSwitchCount     Int       @default(0)
  /// Actual time spent
  timeTakenSeconds   Int?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  exam               Exam      @relation(fields: [examId], references: [id])
  student            Student   @relation(fields: [studentId], references: [id])

  @@unique([examId, studentId])
  @@index([examId])
  @@index([studentId])
  @@index([status])
}

model ExamScore {
  id          String     @id @default(cuid())
  examId      String
  studentId   String
  score       Float
  grade       String?
  remarks     String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  scoreTypeId String?
  exam        Exam       @relation(fields: [examId], references: [id], onDelete: Cascade)
  scoreType   ScoreType? @relation(fields: [scoreTypeId], references: [id], onDelete: SetNull)
  student     Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([examId, studentId])
  @@index([examId])
  @@index([studentId])
  @@index([scoreTypeId])
  @@index([createdAt])
  @@index([examId, studentId])
}

model TeacherComment {

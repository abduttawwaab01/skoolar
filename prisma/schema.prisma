generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// ========================================
// SKOOLAR - Multi-School SaaS Platform
// ========================================

model School {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  logo            String?
  address         String?
  motto           String?
  phone           String?
  email           String?
  website         String?
  primaryColor    String   @default("#059669")
  secondaryColor  String   @default("#10B981")
  region          String?
  plan            String   @default("basic")
  isActive        Boolean  @default(true)
  maxStudents     Int      @default(500)
  maxTeachers     Int      @default(50)
  foundedDate     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  // Relations - each model that has schoolId needs to be listed here
  academicYears      AcademicYear[]
  classes            Class[]
  subjects           Subject[]
  users              User[]
  students           Student[]
  teachers           Teacher[]
  parents            Parent[]
  accountants        Accountant[]
  librarians         Librarian[]
  directors          Director[]
  feeStructures      FeeStructure[]
  payments           Payment[]
  books              LibraryBook[]
  borrowRecords      BorrowRecord[]
  auditLogs          AuditLog[]
  exportLogs         ExportLog[]
  announcements      Announcement[]
  events             SchoolEvent[]
  idCardTemplates    IDCardTemplate[]
  reportTemplates    ReportCardTemplate[]
  behaviorLogs       BehaviorLog[]
  achievements       Achievement[]
  healthRecords      HealthRecord[]
  transportRoutes    TransportRoute[]
  feedbacks          Feedback[]
  terms              Term[]
  notificationList   Notification[]
  exams              Exam[]
  teacherComments    TeacherComment[]
   attendances        Attendance[]
   attendanceScanLogs AttendanceScanLog[]
   reportCards        ReportCard[]
   registrationCodes  RegistrationCode[]
   homeworks          Homework[]
   homeworkSubmissions HomeworkSubmission[]
   videoLessons       VideoLesson[]
   settings            SchoolSettings?
   domainGrades        DomainGrade[]
   scoreTypes          ScoreType[]
   supportTickets      SupportTicket[]
   platformPayments    PlatformPayment[]
   subscriptionPlan    SubscriptionPlan?  @relation("SchoolPlan", fields: [planId], references: [id])
   conversations        Conversation[]
   messages            Message[]
   schoolNotices       SchoolNotice[]
   studentDiaries      StudentDiary[]
   weeklyEvaluations   WeeklyEvaluation[]
   entranceExams       EntranceExam[]

   planId              String?

  @@index([slug])
  @@index([region])
}

model RegistrationCode {
  id          String   @id @default(cuid())
  code        String   @unique
  plan        String   @default("basic")
  region      String?
  maxUses     Int      @default(1)
  usedCount   Int      @default(0)
  expiresAt   DateTime?
  isUsed      Boolean  @default(false)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  schoolId    String?
  school      School?  @relation(fields: [schoolId], references: [id])
  @@index([code])
  @@index([schoolId])
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?
  name          String
  username      String?
  avatar        String?
  phone         String?
  role          String
  schoolId      String?
  isActive      Boolean   @default(true)
  lastLogin     DateTime?
  loginCount    Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  school        School?   @relation(fields: [schoolId], references: [id])
  auditLogs     AuditLog[] @relation("AuditLogsByUser")
  sessions      UserSession[]
  notifications Notification[]
  studentProfile   Student?
  teacherProfile   Teacher?
  parentProfile    Parent?
  accountantProfile Accountant?
  librarianProfile  Librarian?
  directorProfile   Director?

  @@index([schoolId])
  @@index([role])
}

model UserSession {
  id          String   @id @default(cuid())
  userId      String
  token       String?
  ipAddress   String?
  userAgent   String?
  loginAt     DateTime @default(now())
  logoutAt    DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
  @@index([userId])
}

model AcademicYear {
  id          String   @id @default(cuid())
  schoolId    String
  name        String
  startDate   DateTime
  endDate     DateTime
  isCurrent   Boolean  @default(false)
  isLocked    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  school      School   @relation(fields: [schoolId], references: [id])
  terms       Term[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model Term {
  id            String   @id @default(cuid())
  academicYearId String
  schoolId      String
  name          String
  order         Int
  startDate     DateTime
  endDate       DateTime
  isCurrent     Boolean  @default(false)
  isLocked      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  academicYear  AcademicYear @relation(fields: [academicYearId], references: [id])
  school        School       @relation(fields: [schoolId], references: [id])
  exams         Exam[]
  attendance    Attendance[]
  reportCards   ReportCard[]
  teacherComments TeacherComment[]

  @@unique([academicYearId, order])
  @@index([schoolId])
}

model Class {
  id            String   @id @default(cuid())
  schoolId      String
  name          String
  section       String?
  grade         String?
  capacity      Int      @default(40)
  classTeacherId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  school        School   @relation(fields: [schoolId], references: [id])
  classTeacher  Teacher? @relation("ClassTeacher", fields: [classTeacherId], references: [id])
  students      Student[]
  subjects      ClassSubject[]
  exams         Exam[]
  homeworks     Homework[]

  @@unique([schoolId, name, section])
  @@index([schoolId])
}

model Subject {
  id            String   @id @default(cuid())
  schoolId      String
  name          String
  code          String?
  type          String   @default("core")
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  school        School   @relation(fields: [schoolId], references: [id])
  classes       ClassSubject[]
  exams         Exam[]
  homeworks     Homework[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model ClassSubject {
  id          String   @id @default(cuid())
  classId     String
  subjectId   String
  teacherId   String?
  createdAt   DateTime @default(now())

  class       Class    @relation(fields: [classId], references: [id])
  subject     Subject  @relation(fields: [subjectId], references: [id])
  teacher     Teacher? @relation(fields: [teacherId], references: [id])

  @@unique([classId, subjectId])
  @@index([classId])
  @@index([subjectId])
}

model Student {
  id              String   @id @default(cuid())
  schoolId        String
  userId          String   @unique
  admissionNo     String
  classId         String?
  parentIds       String
  dateOfBirth     DateTime?
  gender          String?
  address         String?
  bloodGroup      String?
  allergies       String?
  emergencyContact String?
  photo           String?
  house           String?
  isPromoted      Boolean  @default(true)
  gpa             Float    @default(0.0)
  cumulativeGpa   Float    @default(0.0)
  rank            Int?
  behaviorScore   Int      @default(100)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  school          School   @relation(fields: [schoolId], references: [id])
  user            User     @relation(fields: [userId], references: [id])
  class           Class?   @relation(fields: [classId], references: [id])
  attendance      Attendance[]
  examScores      ExamScore[]
  reportCards     ReportCard[]
  borrowRecords   BorrowRecord[]
  behaviorLogs    BehaviorLog[]
  achievements    Achievement[]
  teacherComments TeacherComment[]
   payments        Payment[]
   homeworkSubmissions HomeworkSubmission[]
   examAttempts       ExamAttempt[]
   weeklyEvaluations   WeeklyEvaluation[]

   @@unique([schoolId, admissionNo])
   @@index([schoolId])
   @@index([classId])
 }

model Teacher {
  id              String   @id @default(cuid())
  schoolId        String
  userId          String   @unique
  employeeNo      String
  specialization String?
  qualification   String?
  dateOfJoining   DateTime?
  gender          String?
  phone           String?
  address         String?
  photo           String?
  salary          Float?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

   school          School   @relation(fields: [schoolId], references: [id])
   user            User     @relation(fields: [userId], references: [id])
   classes         Class[]  @relation("ClassTeacher")
   classSubjects   ClassSubject[]
   exams           Exam[]
   comments        TeacherComment[]
   weeklyEvaluations WeeklyEvaluation[]
   attendanceScanLogs AttendanceScanLog[]

   @@unique([schoolId, employeeNo])
   @@index([schoolId])
 }

model Parent {
  id            String   @id @default(cuid())
  schoolId      String
  userId        String   @unique
  occupation    String?
  phone         String?
  address       String?
  childrenIds   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  school        School   @relation(fields: [schoolId], references: [id])
  user          User     @relation(fields: [userId], references: [id])

  @@index([schoolId])
}

model Accountant {
  id            String   @id @default(cuid())
  schoolId      String
  userId        String   @unique
  employeeNo    String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  school        School   @relation(fields: [schoolId], references: [id])
  user          User     @relation(fields: [userId], references: [id])

  @@index([schoolId])
}

model Librarian {
  id            String   @id @default(cuid())
  schoolId      String
  userId        String   @unique
  employeeNo    String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  school        School   @relation(fields: [schoolId], references: [id])
  user          User     @relation(fields: [userId], references: [id])

  @@index([schoolId])
}

model Director {
  id            String   @id @default(cuid())
  schoolId      String
  userId        String   @unique
  employeeNo    String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  school        School   @relation(fields: [schoolId], references: [id])
  user          User     @relation(fields: [userId], references: [id])

  @@index([schoolId])
}

model Exam {
  id                  String   @id @default(cuid())
  schoolId            String
  termId              String
  subjectId           String
  classId             String
  teacherId           String?
  name                String
  type                String   @default("assessment")
  totalMarks          Int      @default(100)
  passingMarks        Int      @default(50)
  date                DateTime?
  duration            Int? /// Duration in minutes
  instructions        String?
  isLocked            Boolean  @default(false)
  isPublished         Boolean  @default(false)
  /// Security settings JSON: { fullscreen, tabSwitchWarning, tabSwitchAutoSubmit, blockCopyPaste, blockRightClick, blockKeyboardShortcuts, webcamMonitor, randomizeQuestions, randomizeOptions, showResultAfterSubmit, negativeMarking, maxTabSwitches, allowCalculator, calculatorMode }
  securitySettings    String?
  allowCalculator     Boolean  @default(true)
  calculatorMode      String   @default("basic") /// "basic" or "scientific"
  shuffleQuestions    Boolean  @default(false)
  shuffleOptions      Boolean  @default(false)
  showResult          Boolean  @default(false) /// Show score to student after submission
  negativeMarking     Float    @default(0) /// Penalty marks per wrong answer (0 = no negative marking)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  deletedAt           DateTime?

  school        School         @relation(fields: [schoolId], references: [id])
  term          Term           @relation(fields: [termId], references: [id])
  subject       Subject        @relation(fields: [subjectId], references: [id])
  class         Class          @relation(fields: [classId], references: [id])
  teacher       Teacher?       @relation(fields: [teacherId], references: [id])
  scoreType     ScoreType?     @relation(fields: [scoreTypeId], references: [id])
  scores        ExamScore[]
  questions     ExamQuestion[]
  attempts      ExamAttempt[]

  scoreTypeId   String?

  @@index([schoolId])
  @@index([termId])
  @@index([classId])
}

model ExamQuestion {
  id              String   @id @default(cuid())
  examId          String
  type            String   @default("MCQ") /// MCQ, MULTI_SELECT, TRUE_FALSE, FILL_BLANK, SHORT_ANSWER, ESSAY, MATCHING
  questionText    String 
  /// For MCQ/MULTI_SELECT/TRUE_FALSE: JSON array of option strings. For MATCHING: JSON { pairs: [{left, right}] }
  options         String?
  /// Correct answer: MCQ=string index/letter, MULTI_SELECT=array, TRUE_FALSE="true"/"false", FILL_BLANK=array of acceptable answers, SHORT_ANSWER=string/array, ESSAY=markdown rubric, MATCHING=JSON
  correctAnswer   String?
  marks           Int      @default(1)
  explanation     String? /// Explanation shown after grading
  mediaUrl        String? /// Image/video/diagram URL for the question
  order           Int      @default(0) /// Display order
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  exam            Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([examId])
  @@index([order])
}

model ExamAttempt {
  id                  String   @id @default(cuid())
  examId              String
  studentId           String
  /// JSON map of questionId -> answer (string for MCQ/TRUE_FALSE/FILL_BLANK/SHORT_ANSWER, array for MULTI_SELECT, string for ESSAY, JSON for MATCHING)
  answers             String?
  autoScore           Float? /// Auto-graded score (for objective questions)
  manualScore         Float? /// Teacher-graded score (for subjective questions)
  finalScore          Float? /// Combined score
  status              String   @default("in_progress") /// in_progress, submitted, graded, timed_out, disqualified
  startedAt           DateTime @default(now())
  submittedAt         DateTime?
  gradedAt            DateTime?
  /// JSON array of security violations: [{ type: "tab_switch", timestamp, count }]
  securityViolations  String?
  tabSwitchCount      Int      @default(0)
  timeTakenSeconds    Int? /// Actual time spent
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  exam            Exam     @relation(fields: [examId], references: [id])
  student         Student  @relation(fields: [studentId], references: [id])

  @@unique([examId, studentId]) /// Only one active attempt per student
  @@index([examId])
  @@index([studentId])
  @@index([status])
}

model ExamScore {
  id          String   @id @default(cuid())
  examId      String
  studentId   String
  score       Float
  grade       String?
  remarks     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  exam        Exam     @relation(fields: [examId], references: [id])
  student     Student  @relation(fields: [studentId], references: [id])
  scoreType   ScoreType? @relation(fields: [scoreTypeId], references: [id])

  scoreTypeId String?

  @@index([examId])
  @@index([studentId])
  @@index([scoreTypeId])
  @@index([createdAt])
  @@unique([examId, studentId])
}

model TeacherComment {
  id            String   @id @default(cuid())
  schoolId      String
  teacherId     String
  studentId     String
  termId        String
  category      String   @default("general")
  comment       String
  isPublished   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  school        School   @relation(fields: [schoolId], references: [id])
  teacher       Teacher  @relation(fields: [teacherId], references: [id])
  student       Student  @relation(fields: [studentId], references: [id])
  term          Term     @relation(fields: [termId], references: [id])

   @@index([schoolId])
   @@index([studentId])
   @@index([termId])
 }

model WeeklyEvaluation {
   id            String   @id @default(cuid())
   schoolId      String
   teacherId     String
   studentId     String
   weekDate      DateTime // Date of the Monday of the week being evaluated
   academicPerformance Int // 1-5 rating
   behavior       Int    // 1-5 rating
   attendance     Int    // 1-5 rating
   homework       Int    // 1-5 rating
   effort         Int?   // Optional 1-5 rating
   comments       String?
   goals          String?
   strengths      String?
   areasToImprove String?
   isShared       Boolean @default(false) // Shared with parent
   createdAt      DateTime @default(now())
   updatedAt      DateTime @updatedAt

   school         School   @relation(fields: [schoolId], references: [id])
   teacher        Teacher  @relation(fields: [teacherId], references: [id])
   student        Student  @relation(fields: [studentId], references: [id])

   @@unique([schoolId, teacherId, studentId, weekDate])
   @@index([schoolId])
   @@index([teacherId])
   @@index([studentId])
   @@index([weekDate])
   @@index([isShared])
 }

model Attendance {
  id            String   @id @default(cuid())
  schoolId      String
  termId        String
  studentId     String
  classId       String
  date          DateTime
  status        String   @default("present")
  method        String   @default("manual")
  remarks       String?
  markedBy      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  school        School   @relation(fields: [schoolId], references: [id])
  term          Term     @relation(fields: [termId], references: [id])
  student       Student  @relation(fields: [studentId], references: [id])

  @@unique([schoolId, studentId, date])
  @@index([schoolId])
  @@index([termId])
  @@index([classId])
  @@index([studentId])
  @@index([date])
}

model AttendanceScanLog {
  id          String   @id @default(cuid())
  schoolId    String
  studentId   String?
  teacherId   String?
  cardId      String?
  scanType    String   @default("qr")
  action      String   @default("attendance")
  status      String   @default("success")
  scannedBy   String?
  ipAddress   String?
  createdAt   DateTime @default(now())

  school      School   @relation(fields: [schoolId], references: [id])
  teacher     Teacher? @relation(fields: [teacherId], references: [id])

  @@index([schoolId])
  @@index([studentId])
  @@index([teacherId])
  @@index([createdAt])
}

model ReportCard {
  id                String   @id @default(cuid())
  schoolId          String
  studentId         String
  termId            String
  classId           String
  totalScore        Float?
  averageScore      Float?
  gpa               Float?
  classRank         Int?
  grade             String?
  teacherComment    String?
  principalComment  String?
  attendanceSummary String?
  behaviorRating    String?
  isPublished       Boolean  @default(false)
  publishedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  school        School   @relation(fields: [schoolId], references: [id])
  student       Student  @relation(fields: [studentId], references: [id])
  term          Term     @relation(fields: [termId], references: [id])

  @@unique([schoolId, studentId, termId])
  @@index([schoolId])
  @@index([termId])
  @@index([classId])
}

model ReportCardTemplate {
  id            String   @id @default(cuid())
  schoolId      String
  name          String   @default("Default")
  headerColor   String   @default("#059669")
  fontFamily    String   @default("Inter")
  showLogo      Boolean  @default(true)
  showMotto     Boolean  @default(true)
  showBarcode   Boolean  @default(true)
  customFooter  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  school        School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
}

model FeeStructure {
  id              String   @id @default(cuid())
  schoolId        String
  name            String
  amount          Float
  frequency       String   @default("termly")
  classIds        String?
  isOptional      Boolean  @default(false)
  isLatePayment   Boolean  @default(true)
  lateFeeAmount   Float?
  lateFeeAfter    Int?
  academicYear    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  school          School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
}

model Payment {
  id              String   @id @default(cuid())
  schoolId        String
  studentId       String
  feeStructureId  String?
  amount          Float
  method          String   @default("cash")
  reference       String?
  status          String   @default("pending")
  termId          String?
  receiptNo       String?
  paidBy          String?
  paidById        String?
  verifiedBy      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  school          School   @relation(fields: [schoolId], references: [id])
  student         Student  @relation(fields: [studentId], references: [id])

  @@index([schoolId])
  @@index([studentId])
  @@index([status])
  @@index([reference])
  @@index([createdAt])
}

model LibraryBook {
  id              String   @id @default(cuid())
  schoolId        String
  title           String
  author          String?
  isbn            String?
  category        String?
  publisher       String?
  year            Int?
  totalCopies     Int      @default(1)
  availableCopies Int      @default(1)
  location        String?
  barcode         String?
  coverImage      String?
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  school          School   @relation(fields: [schoolId], references: [id])
  borrowRecords   BorrowRecord[]

  @@index([schoolId])
  @@index([category])
}

model BorrowRecord {
  id            String   @id @default(cuid())
  schoolId      String
  bookId        String
  studentId     String
  borrowDate    DateTime @default(now())
  dueDate       DateTime
  returnDate    DateTime?
  status        String   @default("borrowed")
  fine          Float    @default(0)
  remarks       String?
  issuedBy      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  school        School   @relation(fields: [schoolId], references: [id])
  book          LibraryBook @relation(fields: [bookId], references: [id])
  student       Student  @relation(fields: [studentId], references: [id])

  @@index([schoolId])
  @@index([studentId])
  @@index([bookId])
  @@index([status])
}

model IDCardTemplate {
  id            String   @id @default(cuid())
  schoolId      String
  name          String   @default("Standard")
  frontLayout   String?
  backLayout    String?
  primaryColor  String   @default("#059669")
  secondaryColor String  @default("#FFFFFF")
  textColor     String   @default("#000000")
  showBarcode   Boolean  @default(true)
  showQRCode    Boolean  @default(true)
  showPhoto     Boolean  @default(true)
  backText      String?
  width         Float    @default(85.6)
  height        Float    @default(53.98)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  school        School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
}

model BehaviorLog {
  id            String   @id @default(cuid())
  schoolId      String
  studentId     String
  type          String
  category      String
  points        Int      @default(0)
  description   String
  reportedBy    String?
  createdAt     DateTime @default(now())

  school        School   @relation(fields: [schoolId], references: [id])
  student       Student  @relation(fields: [studentId], references: [id])

  @@index([schoolId])
  @@index([studentId])
}

model Achievement {
  id            String   @id @default(cuid())
  schoolId      String
  studentId     String
  title         String
  description   String?
  type          String   @default("academic")
  date          DateTime?
  badgeIcon     String?
  createdAt     DateTime @default(now())

  school        School   @relation(fields: [schoolId], references: [id])
  student       Student  @relation(fields: [studentId], references: [id])

  @@index([schoolId])
  @@index([studentId])
}

model Announcement {
  id            String   @id @default(cuid())
  schoolId      String
  title         String
  content       String
  type          String   @default("general")
  targetRoles   String?
  targetClasses String?
  priority      String   @default("normal")
  isPublished   Boolean  @default(false)
  publishedAt   DateTime?
  expiresAt     DateTime?
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  school        School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([priority])
}

model Notification {
  id            String   @id @default(cuid())
  schoolId      String?
  userId        String
  title         String
  message       String
  type          String   @default("info")
  category      String   @default("general")
  isRead        Boolean  @default(false)
  readAt        DateTime?
  actionUrl     String?
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id])
  school        School?  @relation(fields: [schoolId], references: [id])

  @@index([userId])
  @@index([schoolId])
  @@index([isRead])
  @@index([createdAt])
}

model SchoolEvent {
  id            String   @id @default(cuid())
  schoolId      String
  title         String
  description   String?
  startDate     DateTime
  endDate       DateTime?
  location      String?
  type          String   @default("general")
  isAllDay      Boolean  @default(false)
  color         String   @default("#059669")
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  school        School   @relation(fields: [schoolId], references: [id])
  rsvps         EventRSVP[]

  @@index([schoolId])
  @@index([startDate])
}

model AuditLog {
  id            String   @id @default(cuid())
  schoolId      String
  userId        String?
  action        String
  entity        String
  entityId      String?
  details       String?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())

  school        School   @relation(fields: [schoolId], references: [id])
  user          User?    @relation("AuditLogsByUser", fields: [userId], references: [id])

  @@index([schoolId])
  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
}

model ExportLog {
  id            String   @id @default(cuid())
  schoolId      String
  userId        String?
  type          String
  format        String
  filename      String?
  fileSize      Int?
  status        String   @default("success")
  createdAt     DateTime @default(now())

  school        School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model HealthRecord {
  id            String   @id @default(cuid())
  schoolId      String
  studentId     String
  bloodType     String?
  allergies     String?
  conditions    String?
  vaccinations  String?
  height        Float?
  weight        Float?
  vision        String?
  lastCheckup   DateTime?
  notes         String?
  recordedBy    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  school        School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([studentId])
}

model TransportRoute {
  id            String   @id @default(cuid())
  schoolId      String
  name          String
  description   String?
  driverName    String?
  driverPhone   String?
  vehicleNo     String?
  capacity      Int      @default(40)
  stops         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  school        School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
}

model Feedback {
  id            String   @id @default(cuid())
  schoolId      String
  userId        String?
  category      String
  rating        Int      @default(5)
  title         String
  description   String?
  isAnonymous   Boolean  @default(false)
  status        String   @default("open")
  response      String?
  respondedBy   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  school        School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([category])
  @@index([status])
}

model VideoLesson {
  id            String   @id @default(cuid())
  schoolId      String
  title         String
  description   String?
  subjectId     String?
  classId       String?
  contentType   String   @default("video")     // video, text, audio, image, mixed
  content       String?               // Rich text content for text-based lessons
  videoUrl      String?                          // YouTube/Vimeo/R2 video URL
  audioUrl      String?                          // R2 audio URL
  imageUrl      String?                          // R2 image URL
  thumbnailUrl  String?
  duration      Int      @default(0)
  tags          String?
  viewCount     Int      @default(0)
  isFeatured    Boolean  @default(false)
  isPublished   Boolean  @default(true)
  uploadedBy    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  school        School   @relation(fields: [schoolId], references: [id])
  quizzes        LessonQuiz[]

  @@index([schoolId])
  @@index([subjectId])
  @@index([classId])
  @@index([uploadedBy])
  @@index([isFeatured])
  @@index([createdAt])
}

model Homework {
  id            String   @id @default(cuid())
  schoolId      String
  title         String
  description   String
  subjectId     String?
  classId       String?
  teacherId     String?
  dueDate       DateTime
  totalMarks    Int      @default(100)
  status        String   @default("active")
  attachments   String?
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  school        School   @relation(fields: [schoolId], references: [id])
  subject       Subject? @relation(fields: [subjectId], references: [id])
  class         Class?   @relation(fields: [classId], references: [id])
  submissions   HomeworkSubmission[]

  @@index([schoolId])
  @@index([classId])
  @@index([subjectId])
  @@index([teacherId])
  @@index([status])
  @@index([dueDate])
}

model HomeworkSubmission {
  id              String   @id @default(cuid())
  homeworkId      String
  schoolId        String
  studentId       String
  content         String?
  attachments     String?
  status          String   @default("submitted")
  score           Float?
  grade           String?
  teacherComment  String?
  submittedAt     DateTime @default(now())
  gradedAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  homework        Homework @relation(fields: [homeworkId], references: [id])
  school          School   @relation(fields: [schoolId], references: [id])
  student         Student  @relation(fields: [studentId], references: [id])

  @@unique([homeworkId, studentId])
  @@index([schoolId])
  @@index([homeworkId])
  @@index([studentId])
  @@index([status])
  @@index([createdAt])
}

model SchoolSettings {
  id            String   @id @default(cuid())
  schoolId      String   @unique
  scoreSystem   String   @default("midterm_exam")
  fontFamily    String   @default("Inter")
  theme         String   @default("default")
  schoolMotto   String?
  schoolVision  String?
  schoolMission String?
  principalName String?
  vicePrincipalName String?
  nextTermBegins String?
  academicSession String?
  disabledFeatures String?                        // JSON array of disabled feature IDs
  disabledUserRoles String?                       // JSON array of disabled role types (e.g. TEACHER, DIRECTOR)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  school        School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
}

model ScoreType {
  id          String   @id @default(cuid())
  schoolId    String
  name        String
  type        String
  maxMarks    Int      @default(20)
  weight      Float    @default(1.0)
  position    Int      @default(0)
  isInReport  Boolean  @default(true)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school      School   @relation(fields: [schoolId], references: [id])
  examScores  ExamScore[]
  exams       Exam[]

  @@index([schoolId])
  @@index([type])
}

model DomainGrade {
  id          String   @id @default(cuid())
  schoolId    String
  studentId   String
  termId      String
  classId     String

  cognitiveReasoning    String?
  cognitiveMemory       String?
  cognitiveConcentration String?
  cognitiveProblemSolving String?
  cognitiveInitiative    String?
  cognitiveAverage       String?

  psychomotorHandwriting String?
  psychomotorSports      String?
  psychomotorDrawing     String?
  psychomotorPractical   String?
  psychomotorAverage     String?

  affectivePunctuality      String?
  affectiveNeatness         String?
  affectiveHonesty          String?
  affectiveLeadership       String?
  affectiveCooperation      String?
  affectiveAttentiveness    String?
  affectiveObedience        String?
  affectiveSelfControl      String?
  affectivePoliteness       String?
  affectiveAverage          String?

  classTeacherComment    String?
  classTeacherName       String?
  classTeacherSignature  String?
  principalComment       String?
  principalName          String?
  principalSignature     String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school      School   @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, studentId, termId])
  @@index([schoolId])
  @@index([studentId])
  @@index([termId])
}

model SupportTicket {
  id          String   @id @default(cuid())
  schoolId    String?
  userId      String?
  subject     String
  description String
  category    String   @default("general")
  priority    String   @default("medium")
  status      String   @default("open")
  assignedTo  String?
  response    String?
  rating      Int?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school      School?  @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([userId])
  @@index([status])
  @@index([category])
  @@index([priority])
}

model SubscriptionPlan {
  id                  String   @id @default(cuid())
  name                String   @unique
  displayName          String
  price                Float    @default(0)
  yearlyPrice          Float?
  maxStudents         Int      @default(50)
  maxTeachers         Int      @default(5)
  maxClasses          Int      @default(10)
  maxParents           Int      @default(100)
  maxLibraryBooks      Int      @default(500)
  maxVideoLessons      Int      @default(50)
  maxHomeworkPerMonth  Int      @default(100)
  storageLimit        Int      @default(1000)
  supportLevel        String   @default("email")
  customDomain        Boolean  @default(false)
  apiAccess           Boolean  @default(false)
  whiteLabel          Boolean  @default(false)
  features            String
  isActive            Boolean  @default(true)
  paystackPlanCode    String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  schools             School[]  @relation("SchoolPlan")
  payments            PlatformPayment[]

  @@index([isActive])
}

model PlatformPayment {
  id              String   @id @default(cuid())
  schoolId        String
  planId          String
  reference       String   @unique
  amount          Float
  currency        String   @default("NGN")
  channel         String?
  status          String   @default("pending")
  paystackRef     String?
  verifiedAt      DateTime?
  startDate       DateTime
  endDate         DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  school          School   @relation(fields: [schoolId], references: [id])
  plan            SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([schoolId])
  @@index([planId])
  @@index([status])
  @@index([reference])
}

// ========================================
// PLATFORM-LEVEL MODELS (Super Admin managed)
// ========================================

model SchoolNotice {
  id                String   @id @default(cuid())
  schoolId          String
  title             String
  content           String
  category          String   @default("general")  // general, academic, events, sports, exam, emergency, staff
  author            String?
  priority          String   @default("normal")   // normal, important, urgent
  pinned            Boolean  @default(false)
  attachmentsCount  Int      @default(0)
  deletedAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  school            School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([category])
  @@index([priority])
  @@index([pinned])
  @@index([createdAt])
}

model StudentDiary {
  id                String   @id @default(cuid())
  schoolId          String
  studentId         String
  date              String   // YYYY-MM-DD
  mood              String   @default("okay")     // happy, good, okay, bad, terrible
  highlight         String   @default("")
  learned           String   @default("")
  teacherFeedback   String   @default("")
  goalsTomorrow     String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  school            School   @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, studentId, date])
  @@index([schoolId])
  @@index([studentId])
  @@index([date])
}

model PlatformAnnouncement {
  id            String   @id @default(cuid())
  message       String
  type          String   @default("info")       // info, warning, urgent, success
  targetRoles   String?                        // JSON array of roles, null = all
  targetSchools String?                        // JSON array of school IDs, null = all
  linkUrl       String?
  isActive      Boolean  @default(true)
  startsAt      DateTime @default(now())
  expiresAt     DateTime?
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive])
  @@index([startsAt])
  @@index([expiresAt])
}

model PlatformAdvert {
  id            String   @id @default(cuid())
  title         String
  description   String?
  contentType   String   @default("text")      // text, video, audio, image, mixed
  mediaUrl      String?                        // URL for video/audio/image
  mediaType     String?                        // video/mp4, audio/mp3, image/png etc
  imageUrl      String?                        // Cover/thumbnail image
  linkUrl       String?
  linkText      String?                        // Button text (e.g., "Learn More", "Sign Up")
  ctaType       String   @default("link")      // link, button, modal
  htmlContent   String?                        // Rich text/HTML content
  buttonColor   String   @default("#059669")
  targetRoles   String?                        // JSON array of roles, null = all
  targetSchools String?                        // JSON array of school IDs, null = all
  position      Int      @default(0)           // Display order
  autoSwipeMs   Int      @default(5000)        // Auto-swipe interval in ms, 0 = manual only
  isActive      Boolean  @default(true)
  startsAt      DateTime @default(now())
  expiresAt     DateTime?
  impressions   Int      @default(0)
  clicks        Int      @default(0)
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive])
  @@index([position])
  @@index([startsAt])
  @@index([expiresAt])
}

// Dashboard overlay that Super Admin can configure for schools/users
model SchoolOverlay {
  id            String   @id @default(cuid())
  title         String?
  content       String?                // Text content for overlay
  imageUrl      String?                          // Image URL (R2 or external)
  videoUrl      String?                          // Video URL (YouTube/R2)
  mediaType     String   @default("text")       // text, image, video
  overlayStyle  String   @default("modal")      // modal, banner, fullscreen
  backgroundColor String  @default("rgba(0,0,0,0.8)")
  textColor     String   @default("#FFFFFF")
  position      String   @default("center")     // center, top, bottom
  dismissible   Boolean  @default(true)          // Can user dismiss it?
  showOnce      Boolean  @default(false)         // Only show once per user
  linkUrl       String?                          // Optional link on click
  linkText      String?                          // Button text
  isActive      Boolean  @default(true)
  startsAt      DateTime @default(now())
  expiresAt     DateTime?
  targetSchools String?                          // JSON array of school IDs, null = all
  targetRoles   String?                          // JSON array of roles, null = all
  targetUsers   String?                          // JSON array of user IDs
  priority      Int      @default(0)
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive])
  @@index([priority])
  @@index([startsAt])
  @@index([expiresAt])
}

model PreloaderQuote {
  id            String   @id @default(cuid())
  quote         String
  author        String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive])
}

model PlatformSettings {
  id              String   @id @default(cuid())
  siteName        String   @default("Skoolar")
  siteDescription String?
  siteLogo        String?
  siteFavicon     String?
  primaryColor    String   @default("#059669")
  secondaryColor  String   @default("#10B981")
  accentColor     String   @default("#F59E0B")
  contactEmail    String?
  contactPhone    String?
  contactAddress  String?
  socialLinks     String?                        // JSON: { facebook, twitter, instagram, linkedin, youtube }
  enablePreloader Boolean  @default(true)
  enableAdverts   Boolean  @default(true)
  enableAnnouncements Boolean @default(true)
  heroTitle       String?
  heroSubtitle    String?
  heroImageUrl    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model BlogPost {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  excerpt       String?
  content       String                        // Rich text / markdown
  coverImage    String?
  authorName    String
  authorAvatar  String?
  category      String   @default("General")
  tags          String?                        // JSON array
  isPublished   Boolean  @default(false)
  publishedAt   DateTime?
  featured      Boolean  @default(false)
  readTime      Int      @default(5)           // minutes
  viewCount     Int      @default(0)
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isPublished])
  @@index([category])
}

model DashboardOverlay {
  id            String   @id @default(cuid())
  title         String?
  content       String                // Text/markdown content
  contentType   String   @default("text")      // text, image, video, html
  mediaUrl      String?                         // Image/video URL
  linkUrl       String?
  linkText      String?                         // Button text
  targetRoles   String?                         // JSON array of roles, null = all
  targetSchools String?                         // JSON array of school IDs, null = all
  targetUsers   String?                         // JSON array of user IDs, null = all
  position      String   @default("center")     // center, top, bottom
  bgColor       String   @default("#059669")
  textColor     String   @default("#ffffff")
  isDismissible Boolean  @default(true)
  isActive      Boolean  @default(true)
  startsAt      DateTime @default(now())
  expiresAt     DateTime?
  priority      Int      @default(0)
  dismissDays   Int      @default(1)             // Days before showing again
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive])
  @@index([priority])
  @@index([startsAt])
  @@index([expiresAt])
}

model LessonQuiz {
  id            String   @id @default(cuid())
  lessonId      String
  title         String
  description   String?
  timeLimit     Int?                            // Seconds, null = no limit
  passingScore  Int      @default(60)            // Percentage
  showResults   Boolean  @default(true)
  isPublished   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lesson        VideoLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions     LessonQuizQuestion[]
  attempts      LessonQuizAttempt[]

  @@index([lessonId])
}

model LessonQuizQuestion {
  id            String   @id @default(cuid())
  quizId        String
  type          String   @default("MCQ")         // MCQ, TRUE_FALSE, FILL_BLANK, SHORT_ANSWER
  questionText  String 
  options       String?                // JSON array for MCQ options
  correctAnswer String?                // Correct answer
  marks         Int      @default(1)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  quiz          LessonQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
}

model LessonQuizAttempt {
  id            String   @id @default(cuid())
  quizId        String
  studentId     String
  answers       String?                // JSON: questionId -> answer
  score         Float?
  percentage    Float?
  totalMarks    Int
  status        String   @default("in_progress") // in_progress, completed, passed, failed
  passed        Boolean?
  createdAt     DateTime @default(now())

  quiz          LessonQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@index([studentId])
}

model PlatformStory {
  id            String   @id @default(cuid())
  title         String
  excerpt       String?
  content       String                        // Full story content (rich text)
  coverImage    String?
  level         String?                        // e.g., "Beginner", "Intermediate", "Advanced"
  grade         String?                        // e.g., "JSS 1", "SSS 3"
  category      String   @default("General")
  tags          String?                        // JSON array
  authorName    String?
  authorBio     String?
  submittedBy   String?                        // User ID of submitter (if submitted)
  isFeatured    Boolean  @default(false)
  isPublished   Boolean  @default(false)
  publishedAt   DateTime?
  readTime      Int      @default(10)
  viewCount     Int      @default(0)
  likeCount     Int      @default(0)
  approvedBy    String?
  approvedAt    DateTime?
  rejectedAt    DateTime?
  rejectionReason String?
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isPublished])
  @@index([level])
  @@index([grade])
  @@index([category])
  @@index([isFeatured])
  @@index([publishedAt])
  @@index([createdAt])
}

model StorySubmission {
  id            String   @id @default(cuid())
  title         String
  content       String
  authorName    String
  authorEmail   String
  authorPhone   String?
  level         String?
  grade         String?
  category      String   @default("General")
  coverImage    String?
  status        String   @default("pending")    // pending, approved, rejected
  adminNotes    String?
  reviewedBy    String?
  reviewedAt    DateTime?
  storyId       String?                        // ID of published story (after approval)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([category])
}

// ========================================
// LEARNING HUB MODELS
// ========================================

model HubUser {
  id              String   @id @default(cuid())
  userId          String?  @unique
  displayName     String   @unique
  email           String?
  avatar          String?
  bio             String?
  points          Int      @default(0)
  level           Int      @default(1)
  badge           String   @default("newcomer")
  totalPosts      Int      @default(0)
  totalReviews    Int      @default(0)
  totalLikes      Int      @default(0)
  gamesCreated    Int      @default(0)
  funFactsShared Int      @default(0)
  isBanned        Boolean  @default(false)
  bannedBy        String?
  bannedAt        DateTime?
  banReason       String?
  lastSeenAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  posts           HubPost[]
  reviews         HubReview[]
  comments        HubComment[]
  likes           HubLike[]
  games           HubGame[]
  funFacts        HubFunFact[]
  achievements    HubAchievement[]

  @@index([points])
  @@index([level])
  @@index([badge])
  @@index([displayName])
}

model HubPost {
  id              String   @id @default(cuid())
  hubUserId       String
  channelId       String?
  title           String?
  content         String 
  contentType     String   @default("text")
  category        String   @default("general")
  tags            String?
  attachments     String?
  imageUrl        String?
  likeCount       Int      @default(0)
  commentCount    Int      @default(0)
  viewCount       Int      @default(0)
  downloadCount   Int      @default(0)
  isPinned        Boolean  @default(false)
  isFeatured      Boolean  @default(false)
  isFlagged       Boolean  @default(false)
  flagReason      String?
  isHidden        Boolean  @default(false)
  hiddenBy        String?
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  author          HubUser  @relation(fields: [hubUserId], references: [id], onDelete: Cascade)
  reviews         HubReview[]
  comments        HubComment[]
  likes           HubLike[]
  channel         HubChannel? @relation(fields: [channelId], references: [id])

  @@index([hubUserId])
  @@index([channelId])
  @@index([contentType])
  @@index([category])
  @@index([isPinned])
  @@index([isFeatured])
  @@index([createdAt])
}

model HubReview {
  id              String   @id @default(cuid())
  hubUserId       String
  postId          String
  rating          Int      @default(5)
  title           String?
  content         String 
  reviewType      String   @default("general")
  isFlagged       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  author          HubUser  @relation(fields: [hubUserId], references: [id], onDelete: Cascade)
  post            HubPost  @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([hubUserId])
  @@index([postId])
  @@index([rating])
  @@index([createdAt])
}

model HubComment {
  id              String   @id @default(cuid())
  hubUserId       String
  postId          String?
  parentId        String?
  content         String 
  likeCount       Int      @default(0)
  isFlagged       Boolean  @default(false)
  isHidden        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  author          HubUser  @relation(fields: [hubUserId], references: [id], onDelete: Cascade)
  post            HubPost? @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent          HubComment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies         HubComment[] @relation("CommentReplies")
  likes           HubLike[]

  @@index([hubUserId])
  @@index([postId])
  @@index([parentId])
  @@index([createdAt])
}

model HubLike {
  id              String   @id @default(cuid())
  hubUserId       String
  postId          String?
  commentId       String?

  author          HubUser     @relation(fields: [hubUserId], references: [id], onDelete: Cascade)
  post            HubPost?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment         HubComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([hubUserId, postId])
  @@unique([hubUserId, commentId])
  @@index([hubUserId])
}

model HubChannel {
  id              String   @id @default(cuid())
  name            String   @unique
  description     String?
  icon            String?
  color           String   @default("#059669")
  sortOrder       Int      @default(0)
  isLocked        Boolean  @default(false)
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  posts           HubPost[]

  @@index([sortOrder])
}

model HubGame {
  id              String   @id @default(cuid())
  hubUserId       String
  title           String
  description     String?
  gameType        String   @default("quiz")
  gameData        String 
  difficulty      String   @default("medium")
  category        String   @default("general")
  playCount       Int      @default(0)
  likeCount       Int      @default(0)
  averageScore    Float    @default(0)
  isPublished     Boolean  @default(true)
  isFeatured      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  author          HubUser  @relation(fields: [hubUserId], references: [id], onDelete: Cascade)

  @@index([hubUserId])
  @@index([gameType])
  @@index([category])
  @@index([playCount])
  @@index([isPublished])
}

model HubFunFact {
  id              String   @id @default(cuid())
  hubUserId       String
  content         String 
  category        String   @default("general")
  source          String?
  likeCount       Int      @default(0)
  isFeatured      Boolean  @default(false)
  isFlagged       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  author          HubUser  @relation(fields: [hubUserId], references: [id], onDelete: Cascade)

  @@index([hubUserId])
  @@index([category])
  @@index([isFeatured])
}

model HubAchievement {
  id              String   @id @default(cuid())
  hubUserId       String
  type            String
  title           String
  description     String?
  icon            String?
  pointsEarned    Int      @default(0)
  createdAt       DateTime @default(now())

  author          HubUser  @relation(fields: [hubUserId], references: [id], onDelete: Cascade)

  @@unique([hubUserId, type])
  @@index([hubUserId])
  @@index([type])
}

// ========================================
// MESSAGING MODELS
// ========================================

model Conversation {
  id              String    @id @default(cuid())
  schoolId        String
  type            String    @default("direct")   // direct, group
  title           String?
  participantIds  String                       // JSON array of user IDs
  lastMessage     String?
  lastMessageAt   DateTime?
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  school          School    @relation(fields: [schoolId], references: [id])
  messages        Message[]

  @@index([schoolId])
}

model Message {
  id              String    @id @default(cuid())
  conversationId  String
  schoolId        String
  senderId        String
  content         String  
  type            String    @default("text")     // text, file, image, system
  fileUrl         String?
  fileName        String?
  isRead          Boolean   @default(false)
  readBy          String?                       // JSON array of user IDs who read it
  createdAt       DateTime  @default(now())

  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  school          School        @relation(fields: [schoolId], references: [id])

  @@index([conversationId])
  @@index([senderId])
  @@index([schoolId])
  @@index([createdAt])
}

// ========================================
// EVENT RSVP MODEL
// ========================================

model EventRSVP {
  id              String    @id @default(cuid())
  eventId         String
  userId          String
  status          String    @default("pending")  // pending, going, not_going, maybe
  createdAt       DateTime  @default(now())

  event           SchoolEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}


// ========================================
// DANGER ZONE - Audit Log for Dangerous Operations
// ========================================

model DangerLog {
  id            String   @id @default(cuid())
  performedBy   String
  action        String
  targetType    String?
  targetId      String?
  details       String?
  ipAddress     String?
  createdAt     DateTime @default(now())

  @@index([action])
  @@index([targetType])
  @@index([createdAt])
}

// ========================================
// ENTRANCE EXAM MODELS
// ========================================

model EntranceExam {
  id              String   @id @default(cuid())
  schoolId        String
  title           String
  description     String?
  code            String   @unique
  type            String   @default("assessment") // assessment, interview
  totalMarks      Int      @default(100)
  passingMarks    Int      @default(50)
  duration        Int?     // Duration in minutes
  instructions    String?
  isActive        Boolean  @default(true)
  securitySettings String? // JSON settings
  allowCalculator Boolean  @default(true)
  calculatorMode  String   @default("basic")
  shuffleQuestions Boolean @default(false)
  shuffleOptions  Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  school          School   @relation(fields: [schoolId], references: [id])
  questions       EntranceExamQuestion[]
  attempts        EntranceExamAttempt[]

  @@index([schoolId])
  @@index([code])
}

model EntranceExamQuestion {
  id              String   @id @default(cuid())
  entranceExamId  String
  type            String   @default("MCQ")
  questionText    String 
  options         String?  // JSON array
  correctAnswer   String?  // JSON or string
  marks           Int      @default(1)
  explanation     String?
  mediaUrl        String?
  order           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  exam            EntranceExam @relation(fields: [entranceExamId], references: [id], onDelete: Cascade)

  @@index([entranceExamId])
  @@index([order])
}

model EntranceExamAttempt {
  id                  String   @id @default(cuid())
  entranceExamId      String
  applicantName       String
  applicantEmail      String?
  applicantPhone      String?
  applicantAddress    String?
  answers             String?  // JSON map
  autoScore           Float?
  manualScore         Float?
  finalScore          Float?
  status              String   @default("in_progress") // in_progress, submitted, graded, disqualified
  startedAt           DateTime @default(now())
  submittedAt         DateTime?
  gradedAt            DateTime?
  securityViolations  String?  // JSON
  tabSwitchCount      Int      @default(0)
  timeTakenSeconds    Int?
  aiSuggestions       String?  // Text/JSON from AI analysis
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  exam                EntranceExam @relation(fields: [entranceExamId], references: [id])

  @@index([entranceExamId])
  @@index([status])
}

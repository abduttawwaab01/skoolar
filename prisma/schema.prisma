model Achievement {
  id          String    @id @default(cuid())
  schoolId    String
  studentId   String
  title       String
  description String?
  type        String    @default("academic")
  date        DateTime?
  badgeIcon   String?
  createdAt   DateTime  @default(now())
  school      School    @relation(fields: [schoolId], references: [id])
  student     Student   @relation(fields: [studentId], references: [id])

  @@index([schoolId])
  @@index([studentId])
}

model Announcement {
  id            String    @id @default(cuid())
  schoolId      String
  title         String
  content       String
  type          String    @default("general")
  targetRoles   String?
  targetClasses String?
  priority      String    @default("normal")
  isPublished   Boolean   @default(false)
  publishedAt   DateTime?
  expiresAt     DateTime?
  createdBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  school        School    @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([priority])
}

model Notification {
  id        String    @id @default(cuid())
  schoolId  String?
  userId    String
  title     String
  message   String
  type      String    @default("info")
  category  String    @default("general")
  isRead    Boolean   @default(false)
  readAt    DateTime?
  actionUrl String?
  createdAt DateTime  @default(now())
  school    School?   @relation(fields: [schoolId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([schoolId])
  @@index([isRead])
  @@index([createdAt])
}

model SchoolEvent {
  id          String      @id @default(cuid())
  schoolId    String
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  location    String?
  type        String      @default("general")
  isAllDay    Boolean     @default(false)
  color       String      @default("#059669")
  createdBy   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  rsvps       EventRSVP[]
  school      School      @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([startDate])
}

model AuditLog {
  id        String   @id @default(cuid())
  schoolId  String
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  school    School   @relation(fields: [schoolId], references: [id])
  user      User?    @relation("AuditLogsByUser", fields: [userId], references: [id])

  @@index([schoolId])
  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
}

model ExportLog {
  id        String   @id @default(cuid())
  schoolId  String
  userId    String?
  type      String
  format    String
  filename  String?
  fileSize  Int?
  status    String   @default("success")
  createdAt DateTime @default(now())
  school    School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model HealthRecord {
  id           String    @id @default(cuid())
  schoolId     String
  studentId    String
  bloodType    String?
  allergies    String?
  conditions   String?
  vaccinations String?
  height       Float?
  weight       Float?
  vision       String?
  lastCheckup  DateTime?
  notes        String?
  recordedBy   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  school       School    @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([studentId])
}

model TransportRoute {
  id          String   @id @default(cuid())
  schoolId    String
  name        String
  description String?
  driverName  String?
  driverPhone String?
  vehicleNo   String?
  capacity    Int      @default(40)
  stops       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  school      School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
}

model Feedback {
  id          String   @id @default(cuid())
  schoolId    String
  userId      String?
  category    String
  rating      Int      @default(5)
  title       String
  description String?
  isAnonymous Boolean  @default(false)
  status      String   @default("open")
  response    String?
  respondedBy String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  school      School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([category])
  @@index([status])
}

model VideoLesson {
  id              String                 @id @default(cuid())
  schoolId        String
  title           String
  description     String?
  subjectId       String?
  classId         String?
  contentType     String                 @default("video")
  content         String?
  videoUrl        String?
  audioUrl        String?
  imageUrl        String?
  thumbnailUrl    String?
  duration        Int                    @default(0)
  tags            String?
  viewCount       Int                    @default(0)
  isFeatured      Boolean                @default(false)
  isPublished     Boolean                @default(true)
  uploadedBy      String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  deletedAt       DateTime?
  quizzes         LessonQuiz[]
  checkpoints     VideoCheckpoint[]
  studentProgress StudentVideoProgress[]
  school          School                 @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([subjectId])
  @@index([classId])
  @@index([uploadedBy])
  @@index([isFeatured])
  @@index([createdAt])
}

model Homework {
  id          String               @id @default(cuid())
  schoolId    String
  title       String
  description String
  subjectId   String?
  classId     String?
  teacherId   String?
  dueDate     DateTime
  totalMarks  Int                  @default(100)
  status      String               @default("active")
  contentType String               @default("text")
  audioUrl    String?
  videoUrl    String?
  attachments String?
  createdBy   String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  deletedAt   DateTime?
  class       Class?               @relation(fields: [classId], references: [id])
  school      School               @relation(fields: [schoolId], references: [id])
  subject     Subject?             @relation(fields: [subjectId], references: [id])
  teacher     Teacher?             @relation(fields: [teacherId], references: [id])
  questions   HomeworkQuestion[]
  submissions HomeworkSubmission[]

  @@index([schoolId])
  @@index([classId])
  @@index([subjectId])
  @@index([teacherId])
  @@index([status])
  @@index([dueDate])
}

model HomeworkSubmission {
  id             String                   @id @default(cuid())
  homeworkId     String
  schoolId       String
  studentId      String
  content        String?
  audioUrl       String?
  attachments    String?
  status         String                   @default("submitted")
  score          Float?
  grade          String?
  teacherComment String?
  submittedAt    DateTime                 @default(now())
  gradedAt       DateTime?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  answers        HomeworkQuestionAnswer[]
  homework       Homework                 @relation(fields: [homeworkId], references: [id])
  school         School                   @relation(fields: [schoolId], references: [id])
  student        Student                  @relation(fields: [studentId], references: [id])

  @@unique([homeworkId, studentId])
  @@index([schoolId])
  @@index([homeworkId])
  @@index([studentId])
  @@index([homeworkId, status])
  @@index([createdAt])
  @@index([status])
}

model HomeworkQuestion {
  id            String                   @id @default(cuid())
  homeworkId    String
  schoolId      String
  type          String                   @default("MCQ")
  questionText  String
  options       String?
  correctAnswer String?
  marks         Int                      @default(1)
  order         Int                      @default(0)
  subjectId     String?
  topic         String?
  createdAt     DateTime                 @default(now())
  homework      Homework                 @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  school        School                   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subject       Subject?                 @relation(fields: [subjectId], references: [id])
  answers       HomeworkQuestionAnswer[]

  @@index([homeworkId])
  @@index([schoolId])
  @@index([subjectId])
  @@index([order])
}

model HomeworkQuestionAnswer {
  id           String             @id @default(cuid())
  questionId   String
  submissionId String
  schoolId     String
  answer       String?
  autoScore    Float?
  manualScore  Float?
  createdAt    DateTime           @default(now())
  question     HomeworkQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  school       School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  submission   HomeworkSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([questionId, submissionId])
  @@index([questionId])
  @@index([submissionId])
  @@index([schoolId])
}

model SchoolSettings {
  id                         String      @id @default(cuid())
  schoolId                   String      @unique
  scoreSystem                String      @default("midterm_exam")
  fontFamily                 String      @default("Inter")
  theme                      String      @default("default")
  schoolMotto                String?
  schoolVision               String?
  schoolMission              String?
  principalName              String?
  vicePrincipalName          String?
  nextTermBegins             String?
  academicSession            String?
  disabledFeatures           String?
  disabledUserRoles          String?
  globalDisabledOverrides    String? // JSON array - features this school re-enables despite global disable
  attendanceLateThreshold    String?     @default("08:00")
  // Report card settings
  gradeScaleId               String?
  reportCardDesignId         String?
  reportCardApprovalRequired Boolean     @default(true)
  autoPromoteEnabled         Boolean     @default(false)
  // Payroll settings
  payrollDay                 Int         @default(25)
  taxRate                    Float       @default(0)
  pensionRate                Float       @default(0)
  enableSalaryAdvance        Boolean     @default(false)
  maxAdvancePercentage       Float       @default(50)
  createdAt                  DateTime    @default(now())
  updatedAt                  DateTime    @updatedAt
  school                     School      @relation(fields: [schoolId], references: [id])
  gradeScale                 GradeScale? @relation(fields: [gradeScaleId], references: [id])

  @@index([schoolId])
}

model ScoreType {
  id         String      @id @default(cuid())
  schoolId   String
  name       String
  type       String
  maxMarks   Int         @default(20)
  weight     Float       @default(1.0)
  position   Int         @default(0)
  isInReport Boolean     @default(true)
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  exams      Exam[]
  examScores ExamScore[]
  school     School      @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([type])
}

model DomainGrade {
  id        String  @id @default(cuid())
  schoolId  String
  studentId String
  termId    String
  classId   String
  designId  String?

  // Cognitive Domain
  cognitiveReasoning      String?
  cognitiveMemory         String?
  cognitiveConcentration  String?
  cognitiveProblemSolving String?
  cognitiveInitiative     String?
  cognitiveAverage        String?

  // Psychomotor Domain
  psychomotorHandwriting String?
  psychomotorSports      String?
  psychomotorDrawing     String?
  psychomotorPractical   String?
  psychomotorAverage     String?

  // Affective Domain
  affectivePunctuality   String?
  affectiveNeatness      String?
  affectiveHonesty       String?
  affectiveLeadership    String?
  affectiveCooperation   String?
  affectiveAttentiveness String?
  affectiveObedience     String?
  affectiveSelfControl   String?
  affectivePoliteness    String?
  affectiveAverage       String?

  // Custom domains (JSON — for extensibility beyond core 3 domains)
  domains String?

  // Comments & Signatures
  classTeacherComment   String?
  classTeacherName      String?
  classTeacherSignature String?
  principalComment      String?
  principalName         String?
  principalSignature    String?

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, studentId, termId])
  @@index([schoolId])
  @@index([studentId])
  @@index([termId])
}

model SupportTicket {
  id          String    @id @default(cuid())
  schoolId    String?
  userId      String?
  subject     String
  description String
  category    String    @default("general")
  priority    String    @default("medium")
  status      String    @default("open")
  assignedTo  String?
  response    String?
  rating      Int?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  school      School?   @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([userId])
  @@index([status])
  @@index([category])
  @@index([priority])
}

model SubscriptionPlan {
  id                  String            @id @default(cuid())
  name                String            @unique
  displayName         String
  price               Float             @default(0)
  yearlyPrice         Float?
  pricingType         String            @default("free")
  maxAdminAccounts    Int               @default(1)
  hasDirectorPortal   Boolean           @default(false)
  hasAccountantPortal Boolean           @default(false)
  hasLibrarianPortal  Boolean           @default(false)
  hasParentPortal     Boolean           @default(false)
  hasAIFeatures       Boolean           @default(false)
  hasPremiumSupport   Boolean           @default(false)
  hasPartnership      Boolean           @default(true)
  maxStudents         Int               @default(30)
  maxTeachers         Int               @default(5)
  maxClasses          Int               @default(10)
  maxParents          Int               @default(100)
  maxLibraryBooks     Int               @default(500)
  maxVideoLessons     Int               @default(50)
  maxHomeworkPerMonth Int               @default(100)
  storageLimit        Int               @default(1000)
  supportLevel        String            @default("email")
  customDomain        Boolean           @default(false)
  apiAccess           Boolean           @default(false)
  whiteLabel          Boolean           @default(false)
  features            String
  isActive            Boolean           @default(true)
  paystackPlanCode    String?
  warningDays         Int               @default(7)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  payments            PlatformPayment[]
  schools             School[]          @relation("SchoolPlan")
  pricing             PlanPricing[]

  @@index([isActive])
}

model PlatformPayment {
  id           String           @id @default(cuid())
  schoolId     String
  planId       String
  reference    String           @unique
  amount       Float
  currency     String           @default("NGN")
  channel      String?
  status       String           @default("pending")
  paystackRef  String?
  verifiedAt   DateTime?
  startDate    DateTime
  endDate      DateTime
  schoolType   String? // school type at time of request: primary, secondary, primary_secondary, higher_institution
  studentCount Int              @default(0)
  duration     String? // "monthly" | "term" | "session"
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  plan         SubscriptionPlan @relation(fields: [planId], references: [id])
  school       School           @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([planId])
  @@index([status])
  @@index([reference])
}

model PlanPricing {
  id           String           @id @default(cuid())
  planId       String
  schoolType   String // "primary" | "secondary" | "primary_secondary" | "higher_institution"
  monthlyPrice Float // 1 month
  termPrice    Float // 4 months
  sessionPrice Float // 10 months
  plan         SubscriptionPlan @relation(fields: [planId], references: [id])

  @@unique([planId, schoolType])
  @@index([planId])
}

model SchoolNotice {
  id               String    @id @default(cuid())
  schoolId         String
  title            String
  content          String
  category         String    @default("general")
  author           String?
  priority         String    @default("normal")
  pinned           Boolean   @default(false)
  attachmentsCount Int       @default(0)
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  school           School    @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([category])
  @@index([priority])
  @@index([pinned])
  @@index([createdAt])
}

model StudentDiary {
  id              String   @id @default(cuid())
  schoolId        String
  studentId       String
  date            String
  mood            String   @default("okay")
  highlight       String   @default("")
  learned         String   @default("")
  teacherFeedback String   @default("")
  goalsTomorrow   String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  school          School   @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, studentId, date])
  @@index([schoolId])
  @@index([studentId])
  @@index([date])
}

model PlatformAnnouncement {
  id            String    @id @default(cuid())
  title         String?
  message       String
  type          String    @default("info")
  targetRoles   String?
  targetSchools String?
  linkUrl       String?
  isActive      Boolean   @default(true)
  startsAt      DateTime  @default(now())
  expiresAt     DateTime?
  createdBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([isActive])
  @@index([startsAt])
  @@index([expiresAt])
}

model PlatformAdvert {
  id            String    @id @default(cuid())
  title         String
  description   String?
  contentType   String    @default("text")
  mediaUrl      String?
  mediaType     String?
  imageUrl      String?
  linkUrl       String?
  linkText      String?
  ctaType       String    @default("link")
  htmlContent   String?
  buttonColor   String    @default("#059669")
  targetRoles   String?
  targetSchools String?
  position      Int       @default(0)
  autoSwipeMs   Int       @default(5000)
  isActive      Boolean   @default(true)
  startsAt      DateTime  @default(now())
  expiresAt     DateTime?
  impressions   Int       @default(0)
  clicks        Int       @default(0)
  createdBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([isActive])
  @@index([position])
  @@index([startsAt])
  @@index([expiresAt])
}

model SchoolOverlay {
  id              String    @id @default(cuid())
  title           String?
  content         String?
  imageUrl        String?
  videoUrl        String?
  mediaType       String    @default("text")
  overlayStyle    String    @default("modal")
  backgroundColor String    @default("rgba(0,0,0,0.8)")
  textColor       String    @default("#FFFFFF")
  position        String    @default("center")
  dismissible     Boolean   @default(true)
  showOnce        Boolean   @default(false)
  linkUrl         String?
  linkText        String?
  isActive        Boolean   @default(true)
  startsAt        DateTime  @default(now())
  expiresAt       DateTime?
  targetSchools   String?
  targetRoles     String?
  targetUsers     String?
  priority        Int       @default(0)
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([isActive])
  @@index([priority])
  @@index([startsAt])
  @@index([expiresAt])
}

model PreloaderQuote {
  id        String   @id @default(cuid())
  quote     String
  author    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model PlatformSettings {
  id                       String   @id @default(cuid())
  siteName                 String   @default("Skoolar")
  siteDescription          String?
  siteLogo                 String?
  siteFavicon              String?
  primaryColor             String   @default("#059669")
  secondaryColor           String   @default("#10B981")
  accentColor              String   @default("#F59E0B")
  contactEmail             String?
  contactPhone             String?
  contactAddress           String?
  socialLinks              String?
  enablePreloader          Boolean  @default(true)
  enableAdverts            Boolean  @default(true)
  enableAnnouncements      Boolean  @default(true)
  heroTitle                String?
  heroSubtitle             String?
  heroImageUrl             String?
  // Payment settings
  paymentBankName          String?
  paymentBankAccount       String?
  paymentBankAccountName   String?
  // Global feature controls
  globallyDisabledFeatures String? // JSON array of feature IDs disabled globally
  globallyDisabledRoles    String? // JSON array of role IDs disabled globally
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model UserPreferences {
  id                 String   @id @default(cuid())
  userId             String   @unique
  language           String   @default("en")
  timezone           String   @default("lagos")
  currency           String   @default("ngn")
  dateFormat         String   @default("dd-mm-yyyy")
  emailNotifications Boolean  @default(true)
  pushNotifications  Boolean  @default(true)
  smsNotifications   Boolean  @default(false)
  soundEnabled       Boolean  @default(true)
  twoFactorEnabled   Boolean  @default(false)
  theme              String   @default("system")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model BlogPost {
  id           String    @id @default(cuid())
  title        String
  slug         String    @unique
  excerpt      String?
  content      String
  coverImage   String?
  authorName   String
  authorAvatar String?
  category     String    @default("General")
  tags         String?
  isPublished  Boolean   @default(false)
  publishedAt  DateTime?
  featured     Boolean   @default(false)
  readTime     Int       @default(5)
  viewCount    Int       @default(0)
  createdBy    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([isPublished])
  @@index([category])
}

model DashboardOverlay {
  id            String    @id @default(cuid())
  title         String?
  content       String
  contentType   String    @default("text")
  mediaUrl      String?
  linkUrl       String?
  linkText      String?
  targetRoles   String?
  targetSchools String?
  targetUsers   String?
  position      String    @default("center")
  bgColor       String    @default("#059669")
  textColor     String    @default("#ffffff")
  isDismissible Boolean   @default(true)
  isActive      Boolean   @default(true)
  startsAt      DateTime  @default(now())
  expiresAt     DateTime?
  priority      Int       @default(0)
  dismissDays   Int       @default(1)
  createdBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([isActive])
  @@index([priority])
  @@index([startsAt])
  @@index([expiresAt])
}

model LessonQuiz {
  id           String               @id @default(cuid())
  lessonId     String
  title        String
  description  String?
  timeLimit    Int?
  passingScore Int                  @default(60)
  showResults  Boolean              @default(true)
  isPublished  Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  lesson       VideoLesson          @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  attempts     LessonQuizAttempt[]
  questions    LessonQuizQuestion[]

  @@index([lessonId])
}

model LessonQuizQuestion {
  id            String     @id @default(cuid())
  quizId        String
  type          String     @default("MCQ")
  questionText  String
  options       String?
  correctAnswer String?
  marks         Int        @default(1)
  order         Int        @default(0)
  subjectId     String?
  topic         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  quiz          LessonQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  subject       Subject?   @relation(fields: [subjectId], references: [id])

  @@index([quizId])
  @@index([subjectId])
}

model LessonQuizAttempt {
  id         String     @id @default(cuid())
  quizId     String
  studentId  String
  answers    String?
  score      Float?
  percentage Float?
  totalMarks Int
  status     String     @default("in_progress")
  passed     Boolean?
  createdAt  DateTime   @default(now())
  quiz       LessonQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student    Student    @relation(fields: [studentId], references: [id])

  @@index([quizId])
  @@index([studentId])
}

model PlatformStory {
  id              String    @id @default(cuid())
  title           String
  excerpt         String?
  content         String
  coverImage      String?
  level           String?
  grade           String?
  category        String    @default("General")
  tags            String?
  authorName      String?
  authorBio       String?
  submittedBy     String?
  isFeatured      Boolean   @default(false)
  isPublished     Boolean   @default(false)
  publishedAt     DateTime?
  audioUrl        String?
  audioDuration   Int?
  audioPlatform   String?
  videoUrl        String?
  videoDuration   Int?
  videoPlatform   String?

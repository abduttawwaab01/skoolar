  isFlagged Boolean      @default(false)
  isHidden  Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  author    HubUser      @relation(fields: [hubUserId], references: [id], onDelete: Cascade)
  parent    HubComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   HubComment[] @relation("CommentReplies")
  post      HubPost?     @relation(fields: [postId], references: [id], onDelete: Cascade)
  likes     HubLike[]

  @@index([hubUserId])
  @@index([postId])
  @@index([parentId])
  @@index([createdAt])
}

model HubLike {
  id        String      @id @default(cuid())
  hubUserId String
  postId    String?
  commentId String?
  comment   HubComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  author    HubUser     @relation(fields: [hubUserId], references: [id], onDelete: Cascade)
  post      HubPost?    @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([hubUserId, postId])
  @@unique([hubUserId, commentId])
  @@index([hubUserId])
}

model HubChannel {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  icon        String?
  color       String    @default("#059669")
  sortOrder   Int       @default(0)
  isLocked    Boolean   @default(false)
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  posts       HubPost[]

  @@index([sortOrder])
}

model HubGame {
  id           String   @id @default(cuid())
  hubUserId    String
  title        String
  description  String?
  gameType     String   @default("quiz")
  gameData     String
  difficulty   String   @default("medium")
  category     String   @default("general")
  playCount    Int      @default(0)
  likeCount    Int      @default(0)
  averageScore Float    @default(0)
  isPublished  Boolean  @default(true)
  isFeatured   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  author       HubUser  @relation(fields: [hubUserId], references: [id], onDelete: Cascade)

  @@index([hubUserId])
  @@index([gameType])
  @@index([category])
  @@index([playCount])
  @@index([isPublished])
}

model HubFunFact {
  id         String   @id @default(cuid())
  hubUserId  String
  content    String
  category   String   @default("general")
  source     String?
  likeCount  Int      @default(0)
  isFeatured Boolean  @default(false)
  isFlagged  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  author     HubUser  @relation(fields: [hubUserId], references: [id], onDelete: Cascade)

  @@index([hubUserId])
  @@index([category])
  @@index([isFeatured])
}

model HubAchievement {
  id           String   @id @default(cuid())
  hubUserId    String
  type         String
  title        String
  description  String?
  icon         String?
  pointsEarned Int      @default(0)
  createdAt    DateTime @default(now())
  author       HubUser  @relation(fields: [hubUserId], references: [id], onDelete: Cascade)

  @@unique([hubUserId, type])
  @@index([hubUserId])
  @@index([type])
}

model Conversation {
  id             String    @id @default(cuid())
  schoolId       String
  type           String    @default("direct")
  title          String?
  participantIds String
  lastMessage    String?
  lastMessageAt  DateTime?
  createdBy      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  school         School    @relation(fields: [schoolId], references: [id])
  messages       Message[]

  @@index([schoolId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  schoolId       String
  senderId       String
  content        String
  type           String       @default("text")
  fileUrl        String?
  fileName       String?
  isRead         Boolean      @default(false)
  readBy         String?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  school         School       @relation(fields: [schoolId], references: [id])

  @@index([conversationId])
  @@index([senderId])
  @@index([schoolId])
  @@index([createdAt])
  @@index([conversationId, isRead, senderId])
}

model EventRSVP {
  id        String      @id @default(cuid())
  eventId   String
  userId    String
  status    String      @default("pending")
  createdAt DateTime    @default(now())
  event     SchoolEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

model DangerLog {
  id          String   @id @default(cuid())
  performedBy String
  action      String
  targetType  String?
  targetId    String?
  details     String?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([action])
  @@index([targetType])
  @@index([createdAt])
}

model EntranceExam {
  id               String                 @id @default(cuid())
  schoolId         String
  title            String
  description      String?
  code             String                 @unique
  type             String                 @default("assessment")
  totalMarks       Int                    @default(100)
  passingMarks     Int                    @default(50)
  duration         Int?
  instructions     String?
  isActive         Boolean                @default(true)
  securitySettings String?
  allowCalculator  Boolean                @default(true)
  calculatorMode   String                 @default("basic")
  shuffleQuestions Boolean                @default(false)
  shuffleOptions   Boolean                @default(false)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  deletedAt        DateTime?
  school           School                 @relation(fields: [schoolId], references: [id])
  attempts         EntranceExamAttempt[]
  questions        EntranceExamQuestion[]

  @@index([schoolId])
  @@index([code])
}

model EntranceExamQuestion {
  id             String       @id @default(cuid())
  entranceExamId String
  type           String       @default("MCQ")
  questionText   String
  options        String?
  correctAnswer  String?
  marks          Int          @default(1)
  explanation    String?
  mediaUrl       String?
  order          Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  exam           EntranceExam @relation(fields: [entranceExamId], references: [id], onDelete: Cascade)

  @@index([entranceExamId])
  @@index([order])
}

model EntranceExamAttempt {
  id                 String       @id @default(cuid())
  entranceExamId     String
  applicantName      String
  applicantEmail     String?
  applicantPhone     String?
  applicantAddress   String?
  answers            String?
  autoScore          Float?
  manualScore        Float?
  finalScore         Float?
  status             String       @default("in_progress")
  startedAt          DateTime     @default(now())
  submittedAt        DateTime?
  gradedAt           DateTime?
  securityViolations String?
  tabSwitchCount     Int          @default(0)
  timeTakenSeconds   Int?
  aiSuggestions      String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  exam               EntranceExam @relation(fields: [entranceExamId], references: [id])

  @@index([entranceExamId])
  @@index([status])
}

model PushSubscription {
  id           String   @id @default(cuid())
  userId       String
  subscription String
  endpoint     String
  userAgent    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@index([userId])
  @@index([endpoint])
}

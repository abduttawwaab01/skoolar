generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model School {
  id                  String                   @id @default(cuid())
  name                String
  slug                String                   @unique
  logo                String?
  address             String?
  motto               String?
  phone               String?
  email               String?
  website             String?
  primaryColor        String                   @default("#059669")
  secondaryColor      String                   @default("#10B981")
  region              String?
  plan                String                   @default("basic")
  isActive            Boolean                  @default(true)
  maxStudents         Int                      @default(500)
  maxTeachers         Int                      @default(50)
  foundedDate         DateTime?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  deletedAt           DateTime?
  planId              String?
  academicYears       AcademicYear[]
  accountants         Accountant[]
  achievements        Achievement[]
  announcements       Announcement[]
  attendances         Attendance[]
  attendanceScanLogs  AttendanceScanLog[]
  auditLogs           AuditLog[]
  behaviorLogs        BehaviorLog[]
  borrowRecords       BorrowRecord[]
  classes             Class[]
  conversations       Conversation[]
  directors           Director[]
  domainGrades        DomainGrade[]
  entranceExams       EntranceExam[]
  exams               Exam[]
  exportLogs          ExportLog[]
  feeStructures       FeeStructure[]
  feedbacks           Feedback[]
  healthRecords       HealthRecord[]
  homeworks           Homework[]
  homeworkQuestions   HomeworkQuestion[]
  homeworkAnswers     HomeworkQuestionAnswer[]
  homeworkSubmissions HomeworkSubmission[]
  idCardTemplates     IDCardTemplate[]
  librarians          Librarian[]
  books               LibraryBook[]
  messages            Message[]
  notificationList    Notification[]
  parents             Parent[]
  payments            Payment[]
  platformPayments    PlatformPayment[]
  registrationCodes   RegistrationCode[]
  reportCards         ReportCard[]
  reportTemplates     ReportCardTemplate[]
  subscriptionPlan    SubscriptionPlan?        @relation("SchoolPlan", fields: [planId], references: [id])
  events              SchoolEvent[]
  schoolNotices       SchoolNotice[]
  settings            SchoolSettings?
  scoreTypes          ScoreType[]
  students            Student[]
  studentDiaries      StudentDiary[]
  subjects            Subject[]
  supportTickets      SupportTicket[]
  teachers            Teacher[]
  teacherComments     TeacherComment[]
  terms               Term[]
  transportRoutes     TransportRoute[]
  users               User[]
  videoLessons        VideoLesson[]
  weeklyEvaluations   WeeklyEvaluation[]

  @@index([slug])
  @@index([region])
}

model RegistrationCode {
  id        String    @id @default(cuid())
  code      String    @unique
  plan      String    @default("basic")
  region    String?
  maxUses   Int       @default(1)
  usedCount Int       @default(0)
  expiresAt DateTime?
  isUsed    Boolean   @default(false)
  createdBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  schoolId  String?
  school    School?   @relation(fields: [schoolId], references: [id])

  @@index([code])
  @@index([schoolId])
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  password          String?
  name              String
  username          String?
  avatar            String?
  phone             String?
  role              String
  schoolId          String?
  isActive          Boolean            @default(true)
  lastLogin         DateTime?
  loginCount        Int                @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  emailVerified     DateTime?
  resetToken        String?
  resetTokenExpiry  DateTime?
  accountantProfile Accountant?
  auditLogs         AuditLog[]         @relation("AuditLogsByUser")
  directorProfile   Director?
  librarianProfile  Librarian?
  notifications     Notification[]
  parentProfile     Parent?
  pushSubscriptions PushSubscription[]
  studentProfile    Student?
  teacherProfile    Teacher?
  school            School?            @relation(fields: [schoolId], references: [id])
  sessions          UserSession[]

  @@index([schoolId])
  @@index([role])
}

model UserSession {
  id        String    @id @default(cuid())
  userId    String
  token     String?
  ipAddress String?
  userAgent String?
  loginAt   DateTime  @default(now())
  logoutAt  DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

model AcademicYear {
  id        String    @id @default(cuid())
  schoolId  String
  name      String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean   @default(false)
  isLocked  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  school    School    @relation(fields: [schoolId], references: [id])
  terms     Term[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model Term {
  id              String           @id @default(cuid())
  academicYearId  String
  schoolId        String
  name            String
  order           Int
  startDate       DateTime
  endDate         DateTime
  isCurrent       Boolean          @default(false)
  isLocked        Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  attendance      Attendance[]
  exams           Exam[]
  reportCards     ReportCard[]
  teacherComments TeacherComment[]
  academicYear    AcademicYear     @relation(fields: [academicYearId], references: [id])
  school          School           @relation(fields: [schoolId], references: [id])

  @@unique([academicYearId, order])
  @@index([schoolId])
}

model Class {
  id             String         @id @default(cuid())
  schoolId       String
  name           String
  section        String?
  grade          String?
  capacity       Int            @default(40)
  classTeacherId String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
  classTeacher   Teacher?       @relation("ClassTeacher", fields: [classTeacherId], references: [id])
  school         School         @relation(fields: [schoolId], references: [id])
  subjects       ClassSubject[]
  exams          Exam[]
  homeworks      Homework[]
  students       Student[]

  @@unique([schoolId, name, section])
  @@index([schoolId])
}

model Subject {
  id          String         @id @default(cuid())
  schoolId    String
  name        String
  code        String?
  type        String         @default("core")
  description String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?
  classes     ClassSubject[]
  exams       Exam[]
  homeworks   Homework[]
  school      School         @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, name])
  @@index([schoolId])
}

model ClassSubject {
  id        String   @id @default(cuid())
  classId   String
  subjectId String
  teacherId String?
  createdAt DateTime @default(now())
  class     Class    @relation(fields: [classId], references: [id])
  subject   Subject  @relation(fields: [subjectId], references: [id])
  teacher   Teacher? @relation(fields: [teacherId], references: [id])

  @@unique([classId, subjectId])
  @@index([classId])
  @@index([subjectId])
}

model Student {
  id                  String               @id @default(cuid())
  schoolId            String
  userId              String               @unique
  admissionNo         String
  classId             String?
  parentIds           String
  dateOfBirth         DateTime?
  gender              String?
  address             String?
  bloodGroup          String?
  allergies           String?
  emergencyContact    String?
  photo               String?
  house               String?
  isPromoted          Boolean              @default(true)
  gpa                 Float                @default(0.0)
  cumulativeGpa       Float                @default(0.0)
  rank                Int?
  behaviorScore       Int                  @default(100)
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  deletedAt           DateTime?
  achievements        Achievement[]
  attendance          Attendance[]
  behaviorLogs        BehaviorLog[]
  borrowRecords       BorrowRecord[]
  examAttempts        ExamAttempt[]
  examScores          ExamScore[]
  homeworkSubmissions HomeworkSubmission[]
  payments            Payment[]
  reportCards         ReportCard[]
  class               Class?               @relation(fields: [classId], references: [id])
  school              School               @relation(fields: [schoolId], references: [id])
  user                User                 @relation(fields: [userId], references: [id])
  teacherComments     TeacherComment[]
  weeklyEvaluations   WeeklyEvaluation[]

  @@unique([schoolId, admissionNo])
  @@index([schoolId])
  @@index([classId])
}

model Teacher {
  id                 String              @id @default(cuid())
  schoolId           String
  userId             String              @unique
  employeeNo         String
  specialization     String?
  qualification      String?
  dateOfJoining      DateTime?
  gender             String?
  phone              String?
  address            String?
  photo              String?
  salary             Float?
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  attendanceScanLogs AttendanceScanLog[]
  classes            Class[]             @relation("ClassTeacher")
  classSubjects      ClassSubject[]
  exams              Exam[]
  school             School              @relation(fields: [schoolId], references: [id])
  user               User                @relation(fields: [userId], references: [id])
  comments           TeacherComment[]
  weeklyEvaluations  WeeklyEvaluation[]

  @@unique([schoolId, employeeNo])
  @@index([schoolId])
}

model Parent {
  id          String    @id @default(cuid())
  schoolId    String
  userId      String    @unique
  occupation  String?
  phone       String?
  address     String?
  childrenIds String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  school      School    @relation(fields: [schoolId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@index([schoolId])
}

model Accountant {
  id         String    @id @default(cuid())
  schoolId   String
  userId     String    @unique
  employeeNo String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  school     School    @relation(fields: [schoolId], references: [id])
  user       User      @relation(fields: [userId], references: [id])

  @@index([schoolId])
}

model Librarian {
  id         String    @id @default(cuid())
  schoolId   String
  userId     String    @unique
  employeeNo String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  school     School    @relation(fields: [schoolId], references: [id])
  user       User      @relation(fields: [userId], references: [id])

  @@index([schoolId])
}

model Director {
  id         String    @id @default(cuid())
  schoolId   String
  userId     String    @unique
  employeeNo String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  school     School    @relation(fields: [schoolId], references: [id])
  user       User      @relation(fields: [userId], references: [id])

  @@index([schoolId])
}

model Exam {
  id               String         @id @default(cuid())
  schoolId         String
  termId           String
  subjectId        String
  classId          String
  teacherId        String?
  name             String
  type             String         @default("assessment")
  totalMarks       Int            @default(100)
  passingMarks     Int            @default(50)
  date             DateTime?
  /// Duration in minutes
  duration         Int?
  instructions     String?
  isLocked         Boolean        @default(false)
  isPublished      Boolean        @default(false)
  /// Security settings JSON: { fullscreen, tabSwitchWarning, tabSwitchAutoSubmit, blockCopyPaste, blockRightClick, blockKeyboardShortcuts, webcamMonitor, randomizeQuestions, randomizeOptions, showResultAfterSubmit, negativeMarking, maxTabSwitches, allowCalculator, calculatorMode }
  securitySettings String?
  allowCalculator  Boolean        @default(true)
  /// "basic" or "scientific"
  calculatorMode   String         @default("basic")
  shuffleQuestions Boolean        @default(false)
  shuffleOptions   Boolean        @default(false)
  /// Show score to student after submission
  showResult       Boolean        @default(false)
  /// Penalty marks per wrong answer (0 = no negative marking)
  negativeMarking  Float          @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?
  scoreTypeId      String?
  class            Class          @relation(fields: [classId], references: [id])
  school           School         @relation(fields: [schoolId], references: [id])
  scoreType        ScoreType?     @relation(fields: [scoreTypeId], references: [id])
  subject          Subject        @relation(fields: [subjectId], references: [id])
  teacher          Teacher?       @relation(fields: [teacherId], references: [id])
  term             Term           @relation(fields: [termId], references: [id])
  attempts         ExamAttempt[]
  questions        ExamQuestion[]
  scores           ExamScore[]

  @@index([schoolId])
  @@index([termId])
  @@index([classId])
  @@index([schoolId, termId, classId])
  @@index([schoolId, deletedAt])
}

model ExamQuestion {
  id            String   @id @default(cuid())
  examId        String
  /// MCQ, MULTI_SELECT, TRUE_FALSE, FILL_BLANK, SHORT_ANSWER, ESSAY, MATCHING
  type          String   @default("MCQ")
  questionText  String
  /// For MCQ/MULTI_SELECT/TRUE_FALSE: JSON array of option strings. For MATCHING: JSON { pairs: [{left, right}] }
  options       String?
  /// Correct answer: MCQ=string index/letter, MULTI_SELECT=array, TRUE_FALSE="true"/"false", FILL_BLANK=array of acceptable answers, SHORT_ANSWER=string/array, ESSAY=markdown rubric, MATCHING=JSON
  correctAnswer String?
  marks         Int      @default(1)
  /// Explanation shown after grading
  explanation   String?
  /// Image/video/diagram URL for the question
  mediaUrl      String?
  /// Display order
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([examId])
  @@index([order])
}

model ExamAttempt {
  id                 String    @id @default(cuid())
  examId             String
  studentId          String
  /// JSON map of questionId -> answer (string for MCQ/TRUE_FALSE/FILL_BLANK/SHORT_ANSWER, array for MULTI_SELECT, string for ESSAY, JSON for MATCHING)
  answers            String?
  /// Auto-graded score (for objective questions)
  autoScore          Float?
  /// Teacher-graded score (for subjective questions)
  manualScore        Float?
  /// Combined score
  finalScore         Float?
  /// in_progress, submitted, graded, timed_out, disqualified
  status             String    @default("in_progress")
  startedAt          DateTime  @default(now())
  submittedAt        DateTime?
  gradedAt           DateTime?
  /// JSON array of security violations: [{ type: "tab_switch", timestamp, count }]
  securityViolations String?
  tabSwitchCount     Int       @default(0)
  /// Actual time spent
  timeTakenSeconds   Int?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  exam               Exam      @relation(fields: [examId], references: [id])
  student            Student   @relation(fields: [studentId], references: [id])

  @@unique([examId, studentId])
  @@index([examId])
  @@index([studentId])
  @@index([status])
}

model ExamScore {
  id          String     @id @default(cuid())
  examId      String
  studentId   String
  score       Float
  grade       String?
  remarks     String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  scoreTypeId String?
  exam        Exam       @relation(fields: [examId], references: [id])
  scoreType   ScoreType? @relation(fields: [scoreTypeId], references: [id])
  student     Student    @relation(fields: [studentId], references: [id])

  @@unique([examId, studentId])
  @@index([examId])
  @@index([studentId])
  @@index([scoreTypeId])
  @@index([createdAt])
}

model TeacherComment {
  id          String   @id @default(cuid())
  schoolId    String
  teacherId   String
  studentId   String
  termId      String
  category    String   @default("general")
  comment     String
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  school      School   @relation(fields: [schoolId], references: [id])
  student     Student  @relation(fields: [studentId], references: [id])
  teacher     Teacher  @relation(fields: [teacherId], references: [id])
  term        Term     @relation(fields: [termId], references: [id])

  @@index([schoolId])
  @@index([studentId])
  @@index([termId])
}

model WeeklyEvaluation {
  id                  String   @id @default(cuid())
  schoolId            String
  teacherId           String
  studentId           String
  weekDate            DateTime
  academicPerformance Int
  behavior            Int
  attendance          Int
  homework            Int
  effort              Int?
  comments            String?
  goals               String?
  strengths           String?
  areasToImprove      String?
  isShared            Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  school              School   @relation(fields: [schoolId], references: [id])
  student             Student  @relation(fields: [studentId], references: [id])
  teacher             Teacher  @relation(fields: [teacherId], references: [id])

  @@unique([schoolId, teacherId, studentId, weekDate])
  @@index([schoolId])
  @@index([teacherId])
  @@index([studentId])
  @@index([weekDate])
  @@index([isShared])
}

model Attendance {
  id        String   @id @default(cuid())
  schoolId  String
  termId    String
  studentId String
  classId   String
  date      DateTime
  status    String   @default("present")
  method    String   @default("manual")
  remarks   String?
  markedBy  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id])
  student   Student  @relation(fields: [studentId], references: [id])
  term      Term     @relation(fields: [termId], references: [id])

  @@unique([schoolId, studentId, date])
  @@index([schoolId])
  @@index([termId])
  @@index([classId])
  @@index([studentId])
  @@index([date])
  @@index([schoolId, classId, date])
  @@index([schoolId, termId, studentId])
}

model AttendanceScanLog {
  id        String   @id @default(cuid())
  schoolId  String
  studentId String?
  teacherId String?
  cardId    String?
  scanType  String   @default("qr")
  action    String   @default("attendance")
  status    String   @default("success")
  scannedBy String?
  ipAddress String?
  createdAt DateTime @default(now())
  school    School   @relation(fields: [schoolId], references: [id])
  teacher   Teacher? @relation(fields: [teacherId], references: [id])

  @@index([schoolId])
  @@index([studentId])
  @@index([teacherId])
  @@index([createdAt])
}

model ReportCard {
  id                String    @id @default(cuid())
  schoolId          String
  studentId         String
  termId            String
  classId           String
  totalScore        Float?
  averageScore      Float?
  gpa               Float?
  classRank         Int?
  grade             String?
  teacherComment    String?
  principalComment  String?
  attendanceSummary String?
  behaviorRating    String?
  isPublished       Boolean   @default(false)
  publishedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?
  school            School    @relation(fields: [schoolId], references: [id])
  student           Student   @relation(fields: [studentId], references: [id])
  term              Term      @relation(fields: [termId], references: [id])

  @@unique([schoolId, studentId, termId])
  @@index([schoolId])
  @@index([termId])
  @@index([classId])
}

model ReportCardTemplate {
  id           String   @id @default(cuid())
  schoolId     String
  name         String   @default("Default")
  headerColor  String   @default("#059669")
  fontFamily   String   @default("Inter")
  showLogo     Boolean  @default(true)
  showMotto    Boolean  @default(true)
  showBarcode  Boolean  @default(true)
  customFooter String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  school       School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
}

model FeeStructure {
  id            String    @id @default(cuid())
  schoolId      String
  name          String
  amount        Float
  frequency     String    @default("termly")
  classIds      String?
  isOptional    Boolean   @default(false)
  isLatePayment Boolean   @default(true)
  lateFeeAmount Float?
  lateFeeAfter  Int?
  academicYear  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  school        School    @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
}

model Payment {
  id             String    @id @default(cuid())
  schoolId       String
  studentId      String
  feeStructureId String?
  amount         Float
  method         String    @default("cash")
  reference      String?
  status         String    @default("pending")
  termId         String?
  receiptNo      String?
  paidBy         String?
  paidById       String?
  verifiedBy     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  school         School    @relation(fields: [schoolId], references: [id])
  student        Student   @relation(fields: [studentId], references: [id])

  @@index([schoolId])
  @@index([studentId])
  @@index([status])
  @@index([reference])
  @@index([createdAt])
}

model LibraryBook {
  id              String         @id @default(cuid())
  schoolId        String
  title           String
  author          String?
  isbn            String?
  category        String?
  publisher       String?
  year            Int?
  totalCopies     Int            @default(1)
  availableCopies Int            @default(1)
  location        String?
  barcode         String?
  coverImage      String?
  description     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?
  borrowRecords   BorrowRecord[]
  school          School         @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([category])
}

model BorrowRecord {
  id         String      @id @default(cuid())
  schoolId   String
  bookId     String
  studentId  String
  borrowDate DateTime    @default(now())
  dueDate    DateTime
  returnDate DateTime?
  status     String      @default("borrowed")
  fine       Float       @default(0)
  remarks    String?
  issuedBy   String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  book       LibraryBook @relation(fields: [bookId], references: [id])
  school     School      @relation(fields: [schoolId], references: [id])
  student    Student     @relation(fields: [studentId], references: [id])

  @@index([schoolId])
  @@index([studentId])
  @@index([bookId])
  @@index([status])
}

model IDCardTemplate {
  id             String   @id @default(cuid())
  schoolId       String
  name           String   @default("Standard")
  frontLayout    String?
  backLayout     String?
  primaryColor   String   @default("#059669")
  secondaryColor String   @default("#FFFFFF")
  textColor      String   @default("#000000")
  showBarcode    Boolean  @default(true)
  showQRCode     Boolean  @default(true)
  showPhoto      Boolean  @default(true)
  backText       String?
  width          Float    @default(85.6)
  height         Float    @default(53.98)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  school         School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
}

model BehaviorLog {
  id          String   @id @default(cuid())
  schoolId    String
  studentId   String
  type        String
  category    String
  points      Int      @default(0)
  description String
  reportedBy  String?
  createdAt   DateTime @default(now())
  school      School   @relation(fields: [schoolId], references: [id])
  student     Student  @relation(fields: [studentId], references: [id])

  @@index([schoolId])
  @@index([studentId])
}

model Achievement {
  id          String    @id @default(cuid())
  schoolId    String
  studentId   String
  title       String
  description String?
  type        String    @default("academic")
  date        DateTime?
  badgeIcon   String?
  createdAt   DateTime  @default(now())
  school      School    @relation(fields: [schoolId], references: [id])
  student     Student   @relation(fields: [studentId], references: [id])

  @@index([schoolId])
  @@index([studentId])
}

model Announcement {
  id            String    @id @default(cuid())
  schoolId      String
  title         String
  content       String
  type          String    @default("general")
  targetRoles   String?
  targetClasses String?
  priority      String    @default("normal")
  isPublished   Boolean   @default(false)
  publishedAt   DateTime?
  expiresAt     DateTime?
  createdBy     String?

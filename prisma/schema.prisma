model ReportCard {
  id        String  @id @default(cuid())
  schoolId  String
  studentId String
  termId    String
  classId   String
  designId  String? // Links to ReportCardDesign used during generation

  // Scores & Grades
  totalScore   Float?
  averageScore Float?
  gpa          Float?
  classRank    Int?
  grade        String?

  // Promotion
  promotionStatus String? // "promoted" | "conditional" | "repeated" | "graduated"

  // Cached subject results (JSON — computed scores per subject at generation time)
  subjectResults String?

  // Comments
  teacherComment   String?
  principalComment String?

  // Attendance
  attendanceSummary String?
  behaviorRating    String?

  // Approval Workflow
  approvalStatus String    @default("draft") // "draft" | "submitted" | "approved" | "published" | "archived"
  version        Int       @default(1)
  submittedAt    DateTime?
  approvedAt     DateTime?
  publishedAt    DateTime?
  archivedAt     DateTime?
  generatedById  String?

  // Watermark
  watermarkText String?

  // Parent acknowledgment
  parentSignature      String?
  parentAcknowledgedAt DateTime?

  // Metadata
  isPublished Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Relations
  school     School               @relation(fields: [schoolId], references: [id])
  student    Student              @relation(fields: [studentId], references: [id])
  term       Term                 @relation(fields: [termId], references: [id])
  design     ReportCardDesign?    @relation(fields: [designId], references: [id])
  approvals  ReportCardApproval[]
  comments   ReportCardComment[]
  deliveries ReportCardDelivery[]

  @@unique([schoolId, studentId, termId])
  @@index([schoolId])
  @@index([termId])
  @@index([classId])
  @@index([approvalStatus])
  @@index([studentId])
}

model ReportCardDesign {

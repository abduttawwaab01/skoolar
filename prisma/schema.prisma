  author        HubUser      @relation(fields: [hubUserId], references: [id], onDelete: Cascade)
  reviews       HubReview[]

  @@index([hubUserId])
  @@index([channelId])
  @@index([contentType])
  @@index([category])
  @@index([isPinned])
  @@index([isFeatured])
  @@index([createdAt])
}

model HubReview {
  id         String   @id @default(cuid())
  hubUserId  String
  postId     String
  rating     Int      @default(5)
  title      String?
  content    String
  reviewType String   @default("general")
  isFlagged  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  author     HubUser  @relation(fields: [hubUserId], references: [id], onDelete: Cascade)
  post       HubPost  @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([hubUserId])
  @@index([postId])
  @@index([rating])
  @@index([createdAt])
}

model HubComment {
  id        String       @id @default(cuid())
  hubUserId String
  postId    String?
  parentId  String?
  content   String
  likeCount Int          @default(0)
  isFlagged Boolean      @default(false)
  isHidden  Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  author    HubUser      @relation(fields: [hubUserId], references: [id], onDelete: Cascade)
  parent    HubComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   HubComment[] @relation("CommentReplies")
  post      HubPost?     @relation(fields: [postId], references: [id], onDelete: Cascade)
  likes     HubLike[]

  @@index([hubUserId])
  @@index([postId])
  @@index([parentId])
  @@index([createdAt])
}

model HubLike {
  id        String      @id @default(cuid())
  hubUserId String
  postId    String?
  commentId String?
  comment   HubComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  author    HubUser     @relation(fields: [hubUserId], references: [id], onDelete: Cascade)
  post      HubPost?    @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([hubUserId, postId])
  @@unique([hubUserId, commentId])
  @@index([hubUserId])
}

model HubChannel {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  icon        String?
  color       String    @default("#059669")
  sortOrder   Int       @default(0)
  isLocked    Boolean   @default(false)
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

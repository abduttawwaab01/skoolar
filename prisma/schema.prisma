  school      School    @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([category])
  @@index([date])
}

model Testimonial {
  id         String   @id @default(cuid())
  name       String
  role       String?
  schoolName String?
  content    String
  rating     Int      @default(5)
  avatar     String?
  isApproved Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model LiveClass {
  id              String    @id @default(cuid())
  schoolId        String?
  classId         String?
  title           String
  description     String?
  type            String    @default("class") // class | meeting | interview
  hostId          String?
  hostName        String
  joinCode        String    @unique
  scheduledAt     DateTime?
  startedAt       DateTime?
  endedAt         DateTime?
  maxParticipants Int       @default(50)
  isRecording     Boolean   @default(false)
  recordingUrl    String?
  settings        Json?
  status          String    @default("scheduled") // scheduled | active | ended | cancelled
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  guestUserId     String?

  school        School?                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class         Class?                  @relation(fields: [classId], references: [id])
  host          User?                   @relation("HostedClasses", fields: [hostId], references: [id])
  guestUser     GuestUser?              @relation(fields: [guestUserId], references: [id])
  participants  LiveClassParticipant[]
  chatMessages  LiveClassChatMessage[]
  polls         LiveClassPoll[]
  whiteboards   LiveClassWhiteboard[]
  attendances   LiveClassAttendance[]
  breakoutRooms LiveClassBreakoutRoom[]

  @@index([schoolId])
  @@index([classId])
  @@index([joinCode])
  @@index([status])
  @@index([hostId])
  @@index([type])
}

model LiveClassParticipant {
  id                String    @id @default(cuid())
  liveClassId       String
  userId            String?
  guestId           String?
  name              String
  email             String?
  avatar            String?
  role              String    @default("participant") // host | co-host | participant
  joinedAt          DateTime  @default(now())
  leftAt            DateTime?
  isHandRaised      Boolean   @default(false)
  isMuted           Boolean   @default(true)
  isVideoOn         Boolean   @default(false)
  isScreenSharing   Boolean   @default(false)
  connectionQuality String? // excellent | good | poor | disconnected
  deviceInfo        Json?

  liveClass LiveClass @relation(fields: [liveClassId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id])

  @@unique([liveClassId, userId, guestId])
  @@index([liveClassId])
  @@index([userId])
}

model LiveClassChatMessage {
  id             String   @id @default(cuid())
  liveClassId    String
  senderId       String?
  senderName     String
  senderAvatar   String?
  message        String
  messageType    String   @default("text") // text | file | system
  fileUrl        String?
  isPinned       Boolean  @default(false)
  isAnnouncement Boolean  @default(false)
  createdAt      DateTime @default(now())

  liveClass LiveClass @relation(fields: [liveClassId], references: [id], onDelete: Cascade)

  @@index([liveClassId])
}

model LiveClassPoll {
  id          String    @id @default(cuid())
  liveClassId String
  question    String
  options     Json // [{ id: string, text: string }]
  isMultiple  Boolean   @default(false)
  isAnonymous Boolean   @default(false)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  closedAt    DateTime?

  liveClass LiveClass           @relation(fields: [liveClassId], references: [id], onDelete: Cascade)
  votes     LiveClassPollVote[]

  @@index([liveClassId])
}

model LiveClassPollVote {
  id        String   @id @default(cuid())
  pollId    String
  userId    String?
  guestId   String?
  optionId  String
  createdAt DateTime @default(now())

  poll LiveClassPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user User?         @relation(fields: [userId], references: [id])

  @@unique([pollId, userId])
  @@unique([pollId, guestId])
}

model LiveClassWhiteboard {
  id          String   @id @default(cuid())
  liveClassId String
  snapshot    Json // tldraw document state
  createdBy   String?
  createdAt   DateTime @default(now())

  liveClass LiveClass @relation(fields: [liveClassId], references: [id], onDelete: Cascade)

  @@index([liveClassId])
}

model LiveClassAttendance {
  id          String    @id @default(cuid())
  liveClassId String
  studentId   String?
  userId      String?
  guestId     String?
  name        String
  joinedAt    DateTime  @default(now())
  leftAt      DateTime?
  duration    Int       @default(0) // seconds attended
  status      String    @default("present")

  liveClass LiveClass @relation(fields: [liveClassId], references: [id], onDelete: Cascade)

  @@index([liveClassId])
  @@index([studentId])
}

model LiveClassBreakoutRoom {
  id             String   @id @default(cuid())
  liveClassId    String
  name           String
  participantIds String[] // array of participant IDs
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  liveClass LiveClass @relation(fields: [liveClassId], references: [id], onDelete: Cascade)

  @@index([liveClassId])
}

// ============================================================================
// ASSESSMENT HUB — Student & Teacher Diagnostic Assessments
// ============================================================================

// ---- STUDENT ASSESSMENT MODELS ----

model StudentAssessment {
  id               String    @id @default(cuid())
  schoolId         String
  termId           String?
  academicYearId   String?
  createdBy        String?
  name             String
  description      String?
  type             String    @default("comprehensive") // comprehensive | subject_knowledge | cognitive | learning_style | affective | psychomotor | skills_21st
  status           String    @default("draft") // draft | published | closed
  aiGenerated      Boolean   @default(false)
  targetScope      String    @default("all_students") // all_students | specific_classes | specific_students
  targetClassIds   String? // JSON string[]
  targetStudentIds String? // JSON string[]
  maxDuration      Int? // minutes
  instructions     String?
  passingThreshold Float? // 0-100
  isAdaptive       Boolean   @default(false)
  metadata         String? // JSON flexible config
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  school          School                      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  term            Term?                       @relation(fields: [termId], references: [id])
  sections        StudentAssessmentSection[]
  questions       StudentAssessmentQuestion[]
  attempts        StudentAssessmentAttempt[]
  results         StudentDomainResult[]
  recommendations StudentRecommendation[]

  @@index([schoolId])
  @@index([status])
  @@index([type])
  @@index([schoolId, status])
}

model StudentAssessmentSection {
  id             String   @id @default(cuid())
  assessmentId   String
  name           String
  description    String?
  domain         String // cognitive | subject_knowledge | learning_style | affective | psychomotor | skills_21st
  order          Int      @default(0)
  timeLimit      Int? // minutes, nullable
  totalQuestions Int      @default(0)
  weight         Float    @default(1.0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  assessment StudentAssessment           @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  questions  StudentAssessmentQuestion[]

  @@unique([assessmentId, order])
  @@index([assessmentId])
}

model StudentAssessmentQuestion {
  id               String   @id @default(cuid())
  sectionId        String
  assessmentId     String
  type             String   @default("MCQ") // MCQ | MULTI_SELECT | TRUE_FALSE | FILL_BLANK | SHORT_ANSWER | ESSAY | LIKERT_SCALE | RANKING | SCENARIO | MATCHING | DRAG_DROP
  questionText     String
  options          String? // JSON
  correctAnswer    String? // JSON
  marks            Int      @default(1)
  difficulty       String   @default("intermediate") // beginner | intermediate | advanced
  skillTag         String? // e.g. "critical_thinking", "quadratic_equations"
  category         String? // for profiling: "visual_learner_indicator"
  explanation      String?
  mediaUrl         String?
  order            Int      @default(0)
  weight           Float    @default(1.0)
  parentQuestionId String? // for branching/adaptive logic
  aiGenerated      Boolean  @default(false)
  discriminator    Float? // statistical quality measure
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  section    StudentAssessmentSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  assessment StudentAssessment        @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([sectionId])
  @@index([skillTag])
  @@index([difficulty])
}

model StudentAssessmentAttempt {
  id                 String    @id @default(cuid())
  assessmentId       String
  studentId          String
  schoolId           String
  status             String    @default("in_progress") // in_progress | submitted | graded | timed_out | disqualified
  answers            String? // JSON map of questionId -> answer
  proctoringData     String? // JSON
  autoScore          Float?
  manualScore        Float?
  finalScore         Float?
  adaptivePath       String? // JSON — question order taken
  startedAt          DateTime  @default(now())
  submittedAt        DateTime?
  gradedAt           DateTime?
  timeTakenSeconds   Int?
  tabSwitchCount     Int       @default(0)
  securityViolations String? // JSON
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  assessment StudentAssessment     @relation(fields: [assessmentId], references: [id])
  student    Student               @relation(fields: [studentId], references: [id])
  school     School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  results    StudentDomainResult[]

  @@unique([assessmentId, studentId])
  @@index([assessmentId])
  @@index([studentId])
  @@index([status])
  @@index([schoolId])
}

model StudentDomainResult {
  id             String   @id @default(cuid())
  assessmentId   String
  studentId      String
  attemptId      String
  sectionId      String?
  domain         String // cognitive | subject_knowledge | ...
  score          Float    @default(0)
  maxScore       Float    @default(0)
  percentage     Float    @default(0)
  masteryLevel   String   @default("beginner") // beginner | intermediate | advanced | mastered
  skillBreakdown String? // JSON per-skill scores
  percentile     Float?
  classRank      Int?
  strengths      String? // JSON
  weaknesses     String? // JSON
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  assessment StudentAssessment        @relation(fields: [assessmentId], references: [id])
  student    Student                  @relation(fields: [studentId], references: [id])
  attempt    StudentAssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, studentId, domain])
  @@index([assessmentId])
  @@index([studentId])
  @@index([domain])
  @@index([masteryLevel])
}

model StudentSkillProfile {
  id              String    @id @default(cuid())
  studentId       String
  schoolId        String
  domain          String
  skillName       String
  masteryScore    Float     @default(0) // 0-100
  lastAssessedAt  DateTime?
  assessmentCount Int       @default(0)
  trend           String    @default("stable") // improving | stable | declining
  confidenceLevel Float? // 0-1 statistical confidence
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([studentId, domain, skillName])
  @@index([studentId])
  @@index([domain])
  @@index([masteryScore])
}

model StudentLearningStyleProfile {
  id             String    @id @default(cuid())
  studentId      String    @unique
  schoolId       String
  visual         Float     @default(0) // 0-100
  auditory       Float     @default(0) // 0-100
  kinesthetic    Float     @default(0) // 0-100
  readingWriting Float     @default(0) // 0-100
  primaryStyle   String? // visual | auditory | kinesthetic | readingWriting
  secondaryStyle String?
  lastAssessedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([schoolId])
}

model StudentRecommendation {
  id                 String    @id @default(cuid())
  studentId          String
  schoolId           String
  assessmentId       String? // source assessment
  domain             String
  skillName          String?
  recommendationType String // study_material | practice_exercise | video_lesson | tutoring | revision_focus | peer_collaboration
  title              String
  description        String?
  resourceUrl        String?
  priority           String    @default("medium") // low | medium | high
  isCompleted        Boolean   @default(false)
  completedAt        DateTime?
  aiGenerated        Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  student    Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  school     School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  assessment StudentAssessment? @relation(fields: [assessmentId], references: [id])

  @@index([studentId])
  @@index([schoolId])
  @@index([priority])
  @@index([isCompleted])
}

model StudentGrowthRecord {
  id              String   @id @default(cuid())
  studentId       String
  schoolId        String
  termId          String?
  snapshotDate    DateTime @default(now())
  overallScore    Float?
  domainScores    String? // JSON
  skillMasteryMap String? // JSON
  gpa             Float?
  behavioralScore Int?
  trend           String   @default("stable") // improving | stable | declining
  createdAt       DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  term    Term?   @relation(fields: [termId], references: [id])

  @@index([studentId])
  @@index([snapshotDate])
  @@index([schoolId])
}

// ---- TEACHER ASSESSMENT MODELS ----

model TeacherAssessment {
  id               String    @id @default(cuid())
  schoolId         String
  termId           String?
  createdBy        String?
  name             String
  description      String?
  type             String    @default("comprehensive") // comprehensive | leadership | pedagogical | classroom_mgmt | subject_expertise | prof_development | interpersonal
  status           String    @default("draft") // draft | published | closed
  aiGenerated      Boolean   @default(false)
  targetTeacherIds String? // JSON string[], null = all teachers
  maxDuration      Int?
  instructions     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  school      School                      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  term        Term?                       @relation(fields: [termId], references: [id])
  sections    TeacherAssessmentSection[]
  taQuestions TeacherAssessmentQuestion[] @relation("TAAssessmentQuestions")
  attempts    TeacherAssessmentAttempt[]
  feedback    Teacher360FeedbackEntry[]

  @@index([schoolId])
  @@index([status])
  @@index([type])
}

model TeacherAssessmentSection {
  id           String   @id @default(cuid())
  assessmentId String
  name         String
  description  String?
  domain       String // leadership | pedagogy | classroom_mgmt | subject_expertise | prof_development | interpersonal
  order        Int      @default(0)
  timeLimit    Int?
  weight       Float    @default(1.0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assessment TeacherAssessment           @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  questions  TeacherAssessmentQuestion[] @relation("TASectionQuestions")

  @@unique([assessmentId, order])
  @@index([assessmentId])
}

model TeacherAssessmentQuestion {
  id             String   @id @default(cuid())
  sectionId      String
  assessmentId   String
  type           String   @default("MCQ") // MCQ | LIKERT_SCALE | SELF_REFLECTION | SCENARIO | OPEN_ENDED | RANKING | 360_PROMPT
  questionText   String
  options        String? // JSON
  domain         String
  competencyTag  String?
  marks          Int      @default(1)
  weight         Float    @default(1.0)
  respondentType String   @default("self") // self | peer | student | admin | parent
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  section    TeacherAssessmentSection @relation("TASectionQuestions", fields: [sectionId], references: [id], onDelete: Cascade)
  assessment TeacherAssessment        @relation("TAAssessmentQuestions", fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([sectionId])
  @@index([respondentType])
}

model TeacherAssessmentAttempt {
  id               String    @id @default(cuid())
  assessmentId     String
  teacherId        String
  schoolId         String
  status           String    @default("in_progress") // in_progress | submitted | graded
  answers          String? // JSON
  domainScores     String? // JSON per-domain scores
  startedAt        DateTime  @default(now())
  submittedAt      DateTime?
  timeTakenSeconds Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  assessment TeacherAssessment @relation(fields: [assessmentId], references: [id])
  teacher    Teacher           @relation(fields: [teacherId], references: [id])
  school     School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, teacherId])
  @@index([assessmentId])
  @@index([teacherId])
  @@index([schoolId])
}

model Teacher360FeedbackEntry {
  id               String   @id @default(cuid())
  teacherId        String
  schoolId         String
  assessmentId     String?
  respondentUserId String
  respondentRole   String // student | peer | admin | parent | self
  domain           String
  competencyTag    String?
  ratings          String? // JSON { score, maxScore, comment }
  comments         String? // JSON array of comments
  isAnonymous      Boolean  @default(true)
  approvalStatus   String   @default("pending") // pending | approved | rejected
  submittedAt      DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  teacher    Teacher            @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  school     School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  assessment TeacherAssessment? @relation(fields: [assessmentId], references: [id])

  @@index([teacherId])
  @@index([schoolId])
  @@index([respondentRole])
  @@index([approvalStatus])
}

model TeacherCompetencyProfile {
  id              String    @id @default(cuid())
  teacherId       String
  schoolId        String
  domain          String
  competencyName  String
  score           Float     @default(0) // 0-100
  trend           String    @default("stable") // improving | stable | declining
  lastAssessedAt  DateTime?
  assessmentCount Int       @default(0)
  evidenceCount   Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([teacherId, domain, competencyName])
  @@index([teacherId])
  @@index([domain])
  @@index([score])
}

model TeacherDevelopmentRecommendation {
  id                 String    @id @default(cuid())
  teacherId          String
  schoolId           String
  domain             String
  competencyName     String?
  recommendationType String // workshop | course | reading | mentoring | observation | certification | conference
  title              String
  description        String?
  resourceUrl        String?
  provider           String?
  duration           String? // e.g. "2 days", "8 weeks"
  cost               Float?
  priority           String    @default("medium") // low | medium | high
  targetDate         DateTime?
  completedAt        DateTime?
  aiGenerated        Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([schoolId])
  @@index([priority])
  @@index([recommendationType])
}

model TeacherObservationRecord {
  id                  String    @id @default(cuid())
  teacherId           String
  schoolId            String
  observerId          String // userId of admin
  date                DateTime  @default(now())
  lessonTopic         String?
  lessonDuration      Int? // minutes
  ratings             String? // JSON { criterionName: { score, notes } }
  overallScore        Float?
  strengths           String?
  areasForImprovement String?
  notes               String?
  followUpAction      String?
  nextObservationDate DateTime?
  status              String    @default("draft") // draft | submitted | reviewed
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([schoolId])
  @@index([observerId])
  @@index([date])
  @@index([status])
}

// ---- SHARED / ADMIN MODELS ----

model AssessmentTemplate {

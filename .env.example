# Skoolar Environment Variables
# Copy this to .env and fill in your values

# ============================================
# REQUIRED - Database (Self-hosted PostgreSQL recommended)
# ============================================
# Self-hosted (Oracle VM):
# DATABASE_URL=postgresql://skoolar:password@localhost:5432/skoolardb?sslmode=disable
#
# Neon (Cloudflare edge compatibility — requires DATABASE_PROVIDER=neon):
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require
#
# Provider mode: 'pg' (default, standard Prisma TCP) or 'neon' (HTTP edge adapter)
DATABASE_PROVIDER=pg
DATABASE_URL=postgresql://skoolar:password@localhost:5432/skoolardb?sslmode=disable

# ============================================
# REQUIRED - Authentication
# Generate at: https://generate-secret.vercel.app/32
# ============================================
NEXTAUTH_SECRET=your-32-character-random-string-here
NEXTAUTH_URL=https://skoolar.org

# ============================================
# REQUIRED - Super Admin Email
# ============================================
SUPER_ADMIN_EMAIL=admin@skoolar.com
NEXT_PUBLIC_SUPER_ADMIN_EMAIL=admin@skoolar.com

# ============================================
# REQUIRED - Payments (Paystack)
# ============================================
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# REQUIRED - File Storage (Cloudflare R2)
# ============================================
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=skoolar
NEXT_PUBLIC_CDN_URL=https://cdn.skoolar.org

# ============================================
# OPTIONAL - Email Provider
# Provider: 'resend' (default), 'smtp' (self-hosted Postfix), or 'log'
# ============================================
EMAIL_PROVIDER=resend
# Resend:
RESEND_API_KEY=re_xxxxxxxxxxxxx
# SMTP (Postfix, Gmail, Mailgun, etc.):
EMAIL_SERVER_HOST=smtp.resend.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_SECURE=false
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=noreply@skoolar.org

# ============================================
# OPTIONAL - Google Sheets (Registration Tracking)
# ============================================
GOOGLE_SHEET_URL=https://script.google.com/macros/s/your-script-id/exec

# ============================================
# OPTIONAL - AI / LLM Provider
# Provider: 'openrouter' (default, free models) or 'local' (self-hosted LLM)
# ============================================
AI_PROVIDER=openrouter
# OpenRouter (default):
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Local LLM (vLLM, Ollama, etc. — must support OpenRouter-compatible /chat/completions):
LOCAL_LLM_BASE_URL=http://localhost:8080/v1
LOCAL_LLM_API_KEY=
LOCAL_LLM_MODEL=

# ============================================
# REQUIRED - Push Notifications (VAPID)
# Generate with: npx web-push generate-vapid-keys
# ============================================
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-public-key
VAPID_PRIVATE_KEY=your-private-key
VAPID_SUBJECT=mailto:your-email@example.com

# ============================================
# REQUIRED - LiveKit (Virtual Classrooms)
# Self-host: docker compose -f docker-compose.livekit.yml up -d
# ============================================
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
LIVEKIT_URL=ws://localhost:7880
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880

# ============================================
# OPTIONAL - Socket.IO (Real-time)
# Only needed if running the standalone Socket.IO server on a different port
# ============================================
SOCKET_PORT=3003
NEXT_PUBLIC_SOCKET_URL=

# ============================================
# OPTIONAL - Rate Limiting (Upstash Redis)
# Falls back to in-memory if not configured
# ============================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
